{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultProject": "console",
  "npmScope": "aglyn",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "affected": {
    "defaultBase": "main"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/nx-cloud",
      "options": {
        "cacheableOperations": ["build", "lint", "test", "e2e"],
        "parallel": 1,
        "useDaemonProcess": true,
        "accessToken": "MmI2Y2NlN2MtNjM4NC00NTQ0LTgxODItNGI3YzMwZTQyZTM1fHJlYWQtd3JpdGU="
      }
    }
  },
  "generators": {
    "@nrwl/js": {
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      }
    },
    "@nrwl/node": {
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      }
    },
    "@nrwl/react": {
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      },
      "application": {
        "swc": true,
        "babel": true
      }
    },
    "@nrwl/next": {
      "application": {
        "swc": true,
        "standaloneConfig": true,
        "linter": "eslint",
        "unitTestRunner": "jest",
        "e2eTestRunner": "cypress"
      },
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      }
    }
  },
  "targetDefaults": {
    "e2e": {
      "inputs": ["default", "^default"]
    },
    "test": {
      "inputs": ["default", "^default", "{workspaceRoot}/jest.preset.js"]
    },
    "lint": {
      "inputs": ["default", "{workspaceRoot}/.eslintrc.js"]
    },
    "build-storybook": {
      "inputs": ["default", "^default", "{workspaceRoot}/.storybook/**/*"]
    },
    "build": {
      "inputs": ["production", "^production"]
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      "{workspaceRoot}/workspace.json",
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/tslint.json",
      "{workspaceRoot}/nx.json"
    ],
    "production": ["default"]
  }
}

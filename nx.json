{
  "implicitDependencies": {
    "workspace.json": "*",
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    },
    "tsconfig.base.json": "*",
    "tslint.json": "*",
    ".eslintrc.json": "*",
    "nx.json": "*"
  },
  "affected": {
    "defaultBase": "main"
  },
  "npmScope": "aglyn",
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/workspace/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "lint", "test", "e2e"]
      }
    }
  },
  "projects": {
    "console": {
      "tags": ["scope:app", "scope:app:console"],
      "implicitDependencies": []
    },
    "console-e2e": {
      "tags": ["scope:app", "scope:app:console"],
      "implicitDependencies": ["console"]
    },
    "shared-ui-react": {
      "tags": ["scope:lib", "scope:shared", "scope:shared:ui"],
      "implicitDependencies": []
    },
    "shared-util": {
      "tags": ["scope:lib", "scope:shared", "scope:shared:util"],
      "implicitDependencies": []
    },
    "shared-feature-mdi-icon": {
      "tags": ["scope:lib", "scope:shared", "scope:shared:data"],
      "implicitDependencies": []
    },
    "website-feature-core": {
      "tags": ["scope:lib", "scope:website", "scope:website:data"],
      "implicitDependencies": []
    },
    "website-feature-react": {
      "tags": ["scope:lib", "scope:website", "scope:website:feature"],
      "implicitDependencies": []
    }
  }
}

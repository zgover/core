{
  "implicitDependencies": {
    "workspace.json": "*",
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    },
    "tsconfig.base.json": "*",
    "tslint.json": "*",
    ".eslintrc.json": "*",
    "nx.json": "*"
  },
  "affected": {
    "defaultBase": "main"
  },
  "npmScope": "aglyn",
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/workspace/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "lint", "test", "e2e"]
      }
    }
  },
  "projects": {
    "console": {
      "tags": []
    },
    "console-e2e": {
      "tags": [],
      "implicitDependencies": ["console"]
    },
    "website": {
      "tags": []
    },
    "shared-tools": {
      "tags": []
    },
    "shared-ui-react": {
      "tags": []
    },
    "feature-mdi-icons": {
      "tags": []
    }
  }
}

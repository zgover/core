{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultProject": "console",
  "npmScope": "aglyn",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "implicitDependencies": {
    "workspace.json": "*",
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    },
    "tsconfig.base.json": "*",
    "tslint.json": "*",
    ".eslintrc.js": "*",
    "nx.json": "*"
  },
  "affected": {
    "defaultBase": "main"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/nx-cloud",
      "options": {
        "cacheableOperations": ["build", "lint", "test", "e2e"],
        "parallel": 1,
        "useDaemonProcess": true,
        "accessToken": "MmI2Y2NlN2MtNjM4NC00NTQ0LTgxODItNGI3YzMwZTQyZTM1fHJlYWQtd3JpdGU="
      }
    }
  },
  "generators": {
    "@nrwl/js": {
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      }
    },
    "@nrwl/node": {
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      }
    },
    "@nrwl/react": {
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      },
      "application": {
        "swc": true,
        "babel": true
      }
    },
    "@nrwl/next": {
      "application": {
        "swc": true,
        "standaloneConfig": true,
        "linter": "eslint",
        "unitTestRunner": "jest",
        "e2eTestRunner": "cypress"
      },
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      }
    }
  }
}

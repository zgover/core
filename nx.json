{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultProject": "console",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "generators": {
    "@nx/js": {
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      }
    },
    "@nx/react": {
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      },
      "application": {
        "swc": true,
        "babel": true
      }
    },
    "@nx/node": {
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      }
    },
    "@nx/next": {
      "application": {
        "swc": true,
        "standaloneConfig": true,
        "linter": "eslint",
        "unitTestRunner": "jest",
        "e2eTestRunner": "cypress",
        "style": "none"
      },
      "library": {
        "buildable": true,
        "publishable": true,
        "includeBabelRc": true,
        "standaloneConfig": true,
        "compiler": "swc",
        "config": "project",
        "testEnvironment": "node",
        "unitTestRunner": "jest",
        "linter": "eslint"
      }
    }
  },
  "targetDefaults": {
    "e2e": {
      "inputs": ["default", "^default"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "@nx/jest:jest": {
      "inputs": ["default", "^default", "{workspaceRoot}/jest.preset.js"],
      "cache": true,
      "options": {
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "@nx/eslint:lint": {
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/tools/eslint-rules/**/*",
        "{workspaceRoot}/eslint.config.mjs"
      ],
      "cache": true
    },
    "@nx/next:build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      "{workspaceRoot}/workspace.json",
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/tslint.json",
      "{workspaceRoot}/nx.json"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/**/*.stories.@(js|jsx|ts|tsx|mdx)",
      "!{projectRoot}/.storybook/**/*",
      "!{projectRoot}/tsconfig.storybook.json",
      "!{projectRoot}/eslint.config.mjs"
    ]
  },
  "useDaemonProcess": true,
  "neverConnectToCloud": true,
  "parallel": 1,
  "defaultBase": "main",
  "analytics": true,
  "pluginsConfig": {}
}

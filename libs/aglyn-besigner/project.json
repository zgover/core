{
  "name": "aglyn-besigner",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/aglyn-besigner/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/aglyn-besigner",
        "main": "libs/aglyn-besigner/src/index.ts",
        "tsConfig": "libs/aglyn-besigner/tsconfig.lib.json",
        "assets": ["libs/aglyn-besigner/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/aglyn-besigner/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/aglyn-besigner"],
      "options": {
        "jestConfig": "libs/aglyn-besigner/jest.config.ts"
      }
    }
  },
  "tags": ["scope:lib", "scope:aglyn", "scope:feature", "aglyn:besigner"]
}

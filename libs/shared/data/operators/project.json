{
  "name": "shared-data-operators",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/data/operators/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/data/operators",
        "main": "libs/shared/data/operators/src/index.ts",
        "tsConfig": "libs/shared/data/operators/tsconfig.lib.json",
        "assets": ["libs/shared/data/operators/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/shared/data/operators/**/*.ts"]
      }
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:data"]
}

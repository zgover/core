{
  "name": "shared-data-enums",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/data/enums/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/data/enums",
        "main": "libs/shared/data/enums/src/index.ts",
        "tsConfig": "libs/shared/data/enums/tsconfig.lib.json",
        "assets": ["libs/shared/data/enums/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:data"]
}

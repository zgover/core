{
  "name": "shared-data-types",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/data/types/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:swc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/shared/data/types",
        "main": "libs/shared/data/types/src/index.ts",
        "tsConfig": "libs/shared/data/types/tsconfig.lib.json",
        "assets": [
          "libs/shared/data/types/*.md"
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "libs/shared/data/types/**/*.ts"
        ]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/libs/shared/data/types"
      ],
      "options": {
        "jestConfig": "libs/shared/data/types/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": [
    "scope:lib",
    "scope:shared",
    "scope:data"
  ]
}

{
  "name": "shared-data-mdi",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/data/mdi/src",
  "projectType": "library",
  "tags": ["scope:lib", "scope:shared", "scope:data"],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/data/mdi",
        "main": "libs/shared/data/mdi/src/index.ts",
        "tsConfig": "libs/shared/data/mdi/tsconfig.lib.json",
        "assets": ["libs/shared/data/mdi/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared/data/mdi"],
      "options": {
        "jestConfig": "libs/shared/data/mdi/jest.config.ts"
      }
    }
  }
}

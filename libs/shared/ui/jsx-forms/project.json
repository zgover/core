{
  "name": "shared-ui-jsx-forms",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/ui/jsx-forms/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/ui/jsx-forms",
        "tsConfig": "libs/shared/ui/jsx-forms/tsconfig.lib.json",
        "project": "libs/shared/ui/jsx-forms/package.json",
        "entryFile": "libs/shared/ui/jsx-forms/src/index.ts",
        "external": ["react/jsx-runtime"],
        "rollupConfig": "@nx/react/plugins/bundle-rollup",
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/shared/ui/jsx-forms/README.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/shared/ui/jsx-forms/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared/ui/jsx-forms"],
      "options": {
        "jestConfig": "libs/shared/ui/jsx-forms/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:ui"]
}

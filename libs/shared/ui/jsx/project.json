{
  "name": "shared-ui-jsx",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/ui/jsx/src",
  "projectType": "library",
  "tags": ["scope:lib", "scope:shared", "scope:ui"],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/ui/jsx",
        "tsConfig": "libs/shared/ui/jsx/tsconfig.lib.json",
        "project": "libs/shared/ui/jsx/package.json",
        "entryFile": "libs/shared/ui/jsx/src/index.ts",
        "external": [
          "react/jsx-runtime",
          "@aglyn/shared-data-mdi",
          "@aglyn/shared-data-mdi/constants/default-icon",
          "@aglyn/shared-ui-theme",
          "@aglyn/shared-util-tools",
          "@aglyn/shared-util-vendor"
        ],
        "rollupConfig": ["@nx/react/plugins/bundle-rollup", "libs/shared/ui/jsx/rollup.config.cjs"],
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/shared/ui/jsx/README.md",
            "input": ".",
            "output": "."
          }
        ],
        "updateBuildableProjectDepsInPackageJson": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared/ui/jsx"],
      "options": {
        "jestConfig": "libs/shared/ui/jsx/jest.config.ts"
      }
    }
  }
}

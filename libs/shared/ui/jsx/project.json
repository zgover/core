{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/ui/jsx/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": ["libs/shared/ui/jsx/**/*.{ts,tsx,js,jsx}"]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/libs/shared/ui/jsx"],
      "options": {
        "jestConfig": "libs/shared/ui/jsx/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:ui"]
}

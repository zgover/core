{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc",
    "rootDir": "../../../../",
    "declaration": true,
    "incremental": false,
    "types": ["@tshelpers", "node", "@jsx"],
    "paths": {
      "@aglyn/shared-util-guards": ["../../../../libs/shared/util/guards/src/index.ts"],
      "@aglyn/shared-util-guards/*": ["../../../../libs/shared/util/guards/src/lib/*"],
      "@aglyn/shared-util-tools": ["../../../../libs/shared/util/tools/src/index.ts"],
      "@aglyn/shared-util-tools/*": ["../../../../libs/shared/util/tools/src/lib/*"],
      "@aglyn/shared-util-vendor": ["../../../../libs/shared/util/vendor/src/index.ts"],
      "@aglyn/shared-util-vendor/*": ["../../../../libs/shared/util/vendor/src/lib/*"],
      "@aglyn/shared-data-types": ["../../../../libs/shared/data/types/src/index.ts"],
      "@aglyn/shared-data-types/*": ["../../../../libs/shared/data/types/src/lib/*"]
    }
  },
  "files": ["../../../../node_modules/@nx/react/typings/cssmodule.d.ts", "../../../../node_modules/@nx/react/typings/image.d.ts"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx",
    "**/*.spec.js",
    "**/*.test.js",
    "**/*.spec.jsx",
    "**/*.test.jsx",
    "jest.config.ts"
  ],
  "include": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx"]
}

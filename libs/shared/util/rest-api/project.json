{
  "name": "shared-util-rest-api",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/util/rest-api/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:swc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/shared/util/rest-api",
        "main": "libs/shared/util/rest-api/src/index.ts",
        "tsConfig": "libs/shared/util/rest-api/tsconfig.lib.json",
        "assets": [
          "libs/shared/util/rest-api/*.md"
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "libs/shared/util/rest-api/**/*.ts"
        ]
      }
    }
  },
  "tags": [
    "scope:lib",
    "scope:shared",
    "scope:util"
  ]
}

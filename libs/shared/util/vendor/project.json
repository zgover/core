{
  "name": "shared-util-vendor",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/util/vendor/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/util/vendor",
        "main": "libs/shared/util/vendor/src/index.ts",
        "tsConfig": "libs/shared/util/vendor/tsconfig.lib.json",
        "assets": ["libs/shared/util/vendor/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/shared/util/vendor/**/*.ts"]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared/util/vendor"],
      "options": {
        "jestConfig": "libs/shared/util/vendor/jest.config.ts"
      }
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:util"]
}

{
  "name": "shared-util-guards",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/util/guards/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/util/guards",
        "main": "libs/shared/util/guards/src/index.ts",
        "tsConfig": "libs/shared/util/guards/tsconfig.lib.json",
        "assets": ["libs/shared/util/guards/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/shared/util/guards/**/*.ts"]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared/util/guards"],
      "options": {
        "jestConfig": "libs/shared/util/guards/jest.config.ts"
      }
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:util"]
}

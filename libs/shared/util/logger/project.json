{
  "name": "shared-util-logger",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/util/logger/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:swc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/shared/util/logger",
        "main": "libs/shared/util/logger/src/index.ts",
        "tsConfig": "libs/shared/util/logger/tsconfig.lib.json",
        "assets": [
          "libs/shared/util/logger/*.md"
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "libs/shared/util/logger/**/*.ts"
        ]
      },
      "outputs": [
        "{options.outputFile}"
      ]
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/libs/shared/util/logger"
      ],
      "options": {
        "jestConfig": "libs/shared/util/logger/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": [
    "scope:lib",
    "scope:shared",
    "scope:util"
  ]
}

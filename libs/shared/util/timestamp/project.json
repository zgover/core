{
  "name": "shared-util-timestamp",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/util/timestamp/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/util/timestamp",
        "main": "libs/shared/util/timestamp/src/index.ts",
        "tsConfig": "libs/shared/util/timestamp/tsconfig.lib.json",
        "assets": ["libs/shared/util/timestamp/*.md"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": ["libs/shared/util/timestamp/**/*.ts"]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared/util/timestamp"],
      "options": {
        "jestConfig": "libs/shared/util/timestamp/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:util"]
}

{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/feature/fb-client/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/feature/fb-client",
        "main": "libs/shared/feature/fb-client/src/index.ts",
        "tsConfig": "libs/shared/feature/fb-client/tsconfig.lib.json",
        "assets": ["libs/shared/feature/fb-client/*.md"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/shared/feature/fb-client/**/*.ts"]
      }
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:feature"]
}

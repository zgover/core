{
  "name": "besigner-ui-color-picker",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/besigner/ui/color-picker/src",
  "projectType": "library",
  "tags": ["scope:lib", "scope:aglyn", "scope:besigner", "scope:ui"],
  "targets": {
    "build": {
      "executor": "@nrwl/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/besigner/ui/color-picker",
        "tsConfig": "libs/besigner/ui/color-picker/tsconfig.lib.json",
        "project": "libs/besigner/ui/color-picker/package.json",
        "entryFile": "libs/besigner/ui/color-picker/src/index.ts",
        "external": ["@emotion/react/jsx-runtime"],
        "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/besigner/ui/color-picker/README.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/besigner/ui/color-picker/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/besigner/ui/color-picker"],
      "options": {
        "jestConfig": "libs/besigner/ui/color-picker/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "storybook": {
      "executor": "@nrwl/storybook:storybook",
      "options": {
        "uiFramework": "@storybook/react",
        "port": 4400,
        "config": {
          "configFolder": "libs/besigner/ui/color-picker/.storybook"
        }
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@nrwl/storybook:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "uiFramework": "@storybook/react",
        "outputPath": "dist/storybook/besigner-ui-color-picker",
        "config": {
          "configFolder": "libs/besigner/ui/color-picker/.storybook"
        }
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    }
  }
}

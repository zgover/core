{
  "root": "libs/core/feature/canvas-designer",
  "sourceRoot": "libs/core/feature/canvas-designer/src",
  "projectType": "library",
  "tags": ["scope:lib", "scope:aglyn", "scope:feature", "aglyn:canvas-designer"],
  "targets": {
    "build": {
      "executor": "@nrwl/web:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/core/feature/canvas-designer",
        "tsConfig": "libs/core/feature/canvas-designer/tsconfig.lib.json",
        "project": "libs/core/feature/canvas-designer/package.json",
        "entryFile": "libs/core/feature/canvas-designer/src/index.ts",
        "external": ["react/jsx-runtime"],
        "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/core/feature/canvas-designer/README.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/core/feature/canvas-designer/**/*.{ts,tsx,js,jsx}"]
      }
    }
  }
}

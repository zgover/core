{
  "name": "core-feature-renderer",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/feature/renderer/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/core/feature/renderer",
        "tsConfig": "libs/core/feature/renderer/tsconfig.lib.json",
        "project": "libs/core/feature/renderer/package.json",
        "entryFile": "libs/core/feature/renderer/src/index.ts",
        "external": ["react/jsx-runtime"],
        "rollupConfig": "@nx/react/plugins/bundle-rollup",
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/core/feature/renderer/README.md",
            "input": ".",
            "output": "."
          }
        ],
        "updateBuildableProjectDepsInPackageJson": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/core/feature/renderer/**/*.{ts,tsx,js,jsx}"]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/core/feature/renderer"],
      "options": {
        "jestConfig": "libs/core/feature/renderer/jest.config.ts"
      }
    }
  },
  "tags": ["scope:lib", "scope:aglyn", "scope:feature", "aglyn:renderer"]
}

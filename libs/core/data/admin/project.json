{
  "name": "core-data-admin",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/data/admin/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/core/data/admin",
        "main": "libs/core/data/admin/src/index.ts",
        "tsConfig": "libs/core/data/admin/tsconfig.lib.json",
        "assets": ["libs/core/data/admin/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/core/data/admin/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/core/data/admin"],
      "options": {
        "jestConfig": "libs/core/data/admin/jest.config.ts"
      }
    }
  },
  "tags": ["scope:lib", "scope:aglyn", "scope:data", "aglyn:tenancy"]
}

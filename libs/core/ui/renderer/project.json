{
  "name": "core-ui-renderer",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/ui/renderer/src",
  "projectType": "library",
  "tags": [
    "scope:lib",
    "scope:aglyn",
    "scope:ui",
    "aglyn:renderer"
  ],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/core/ui/renderer",
        "tsConfig": "libs/core/ui/renderer/tsconfig.lib.json",
        "project": "libs/core/ui/renderer/package.json",
        "entryFile": "libs/core/ui/renderer/src/index.ts",
        "external": [
          "react/jsx-runtime"
        ],
        "rollupConfig": [
          "@nx/react/plugins/bundle-rollup",
          "tools/rollup-suppress-use-client.js",
          "tools/rollup-skip-typecheck.js"
        ],
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/core/ui/renderer/README.md",
            "input": ".",
            "output": "."
          }
        ],
        "updateBuildableProjectDepsInPackageJson": true,
        "skipTypeCheck": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ]
    }
  }
}

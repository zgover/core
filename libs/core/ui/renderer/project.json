{
  "name": "core-ui-renderer",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/ui/renderer/src",
  "projectType": "library",
  "tags": ["scope:lib", "scope:aglyn", "scope:ui", "aglyn:renderer"],
  "implicitDependencies": ["shared-data-jsx"],
  "targets": {
    "build": {
      "executor": "@nrwl/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/core/ui/renderer",
        "tsConfig": "libs/core/ui/renderer/tsconfig.lib.json",
        "project": "libs/core/ui/renderer/package.json",
        "entryFile": "libs/core/ui/renderer/src/index.ts",
        "external": ["react/jsx-runtime"],
        "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/core/ui/renderer/README.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/core/ui/renderer/**/*.{ts,tsx,js,jsx}"]
      }
    }
  }
}

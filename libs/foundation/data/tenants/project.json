{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/foundation/data/tenants/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/foundation/data/tenants",
        "main": "libs/foundation/data/tenants/src/index.ts",
        "tsConfig": "libs/foundation/data/tenants/tsconfig.lib.json",
        "assets": ["libs/foundation/data/tenants/*.md"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/foundation/data/tenants/**/*.ts"]
      }
    }
  },
  "tags": ["scope:lib", "scope:shared", "scope:feature"]
}

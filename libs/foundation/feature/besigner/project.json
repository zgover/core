{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/foundation/feature/besigner/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/web:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/foundation/feature/besigner",
        "tsConfig": "libs/foundation/feature/besigner/tsconfig.lib.json",
        "project": "libs/foundation/feature/besigner/package.json",
        "entryFile": "libs/foundation/feature/besigner/src/index.ts",
        "external": ["react/jsx-runtime"],
        "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/foundation/feature/besigner/README.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "libs/foundation/feature/besigner/**/*.{ts,tsx,js,jsx}"
        ]
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/libs/foundation/feature/besigner"],
      "options": {
        "jestConfig": "libs/foundation/feature/besigner/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["scope:lib", "scope:aglyn", "scope:feature", "aglyn:besigner"]
}

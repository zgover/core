{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/tenant/feature/instance/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/tenant/feature/instance",
        "main": "libs/tenant/feature/instance/src/index.ts",
        "tsConfig": "libs/tenant/feature/instance/tsconfig.lib.json",
        "assets": ["libs/tenant/feature/instance/*.md"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/tenant/feature/instance/**/*.ts"]
      }
    }
  },
  "tags": ["scope:lib", "scope:aglyn", "scope:feature", "scope:tenant"]
}

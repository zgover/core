{
  "name": "aglyn-plugin-mui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/aglyn-plugin-mui/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nrwl/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/aglyn-plugin-mui",
        "tsConfig": "libs/aglyn-plugin-mui/tsconfig.lib.json",
        "project": "libs/aglyn-plugin-mui/package.json",
        "entryFile": "libs/aglyn-plugin-mui/src/index.ts",
        "external": ["react/jsx-runtime"],
        "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
        "compiler": "swc",
        "assets": [
          {
            "glob": "libs/aglyn-plugin-mui/README.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/aglyn-plugin-mui/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/aglyn-plugin-mui"],
      "options": {
        "jestConfig": "libs/aglyn-plugin-mui/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}

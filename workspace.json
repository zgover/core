{
  "version": 2,
  "cli": {
    "defaultCollection": "@nrwl/next"
  },
  "defaultProject": "console",
  "generators": {
    "@nrwl/react": {
      "application": {
        "babel": true
      }
    },
    "@nrwl/next": {
      "application": {
        "style": "@emotion/styled",
        "linter": "eslint"
      }
    }
  },
  "projects": {
    "console": {
      "root": "apps/console",
      "sourceRoot": "apps/console",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "root": "apps/console",
            "outputPath": "dist/apps/console"
          },
          "configurations": {
            "production": {}
          }
        },
        "serve": {
          "executor": "@nrwl/next:server",
          "options": {
            "buildTarget": "console:build",
            "dev": true
          },
          "configurations": {
            "production": {
              "buildTarget": "console:build:production",
              "dev": false
            }
          }
        },
        "export": {
          "executor": "@nrwl/next:export",
          "options": {
            "buildTarget": "console:build:production"
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/console"],
          "options": {
            "jestConfig": "apps/console/jest.config.js",
            "passWithNoTests": true
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/console/**/*.{ts,tsx,js,jsx}"]
          }
        }
      }
    },
    "console-e2e": {
      "root": "apps/console-e2e",
      "sourceRoot": "apps/console-e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "apps/console-e2e/cypress.json",
            "tsConfig": "apps/console-e2e/tsconfig.e2e.json",
            "devServerTarget": "console:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "console:serve:production"
            }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/console-e2e/**/*.{js,ts}"]
          }
        }
      }
    },
    "shared-ui-react": {
      "root": "libs/shared/ui-react",
      "sourceRoot": "libs/shared/ui-react/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/shared/ui-react/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/shared/ui-react"],
          "options": {
            "jestConfig": "libs/shared/ui-react/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "shared-util": {
      "root": "libs/shared/util",
      "sourceRoot": "libs/shared/util/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/shared/util/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/shared/util"],
          "options": {
            "jestConfig": "libs/shared/util/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "shared-feature-mdi-icon": {
      "root": "libs/shared/feature-mdi-icon",
      "sourceRoot": "libs/shared/feature-mdi-icon/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/shared/feature-mdi-icon/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/shared/feature-mdi-icon"],
          "options": {
            "jestConfig": "libs/shared/feature-mdi-icon/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "website-feature-app": {
      "root": "libs/website/feature-app",
      "sourceRoot": "libs/website/feature-app/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/website/feature-app/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/website/feature-app"],
          "options": {
            "jestConfig": "libs/website/feature-app/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    }
  }
}

{
  "version": 2,
  "cli": {
    "defaultCollection": "@nrwl/next"
  },
  "defaultProject": "console",
  "generators": {
    "@nrwl/react": {
      "application": {
        "babel": true
      }
    },
    "@nrwl/next": {
      "application": {
        "style": "@emotion/styled",
        "linter": "eslint"
      }
    }
  },
  "projects": {
    "console": {
      "root": "apps/console",
      "sourceRoot": "apps/console",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "root": "apps/console",
            "outputPath": "dist/apps/console"
          },
          "configurations": {
            "production": {}
          }
        },
        "serve": {
          "executor": "@nrwl/next:server",
          "options": {
            "buildTarget": "console:build",
            "dev": true
          },
          "configurations": {
            "production": {
              "buildTarget": "console:build:production",
              "dev": false
            }
          }
        },
        "export": {
          "executor": "@nrwl/next:export",
          "options": {
            "buildTarget": "console:build:production"
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/console"],
          "options": {
            "jestConfig": "apps/console/jest.config.js",
            "passWithNoTests": true
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/console/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "version": {
          "executor": "@jscutlery/semver:version",
          "options": {
            "syncVersions": false
          }
        }
      }
    },
    "console-e2e": {
      "root": "apps/console-e2e",
      "sourceRoot": "apps/console-e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "apps/console-e2e/cypress.json",
            "tsConfig": "apps/console-e2e/tsconfig.e2e.json",
            "devServerTarget": "console:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "console:serve:production"
            }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/console-e2e/**/*.{js,ts}"]
          }
        }
      }
    },
    "shared-data-mdi": {
      "root": "libs/shared/data/mdi",
      "sourceRoot": "libs/shared/data/mdi/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/shared/data/mdi/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/shared/data/mdi"],
          "options": {
            "jestConfig": "libs/shared/data/mdi/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "shared-ui-react": {
      "root": "libs/shared/ui/react",
      "sourceRoot": "libs/shared/ui/react/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/shared/ui/react/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/shared/ui/react"],
          "options": {
            "jestConfig": "libs/shared/ui/react/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "shared-ui-themes": {
      "root": "libs/shared/ui/themes",
      "sourceRoot": "libs/shared/ui/themes/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/shared/ui/themes/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/shared/ui/themes"],
          "options": {
            "jestConfig": "libs/shared/ui/themes/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "shared-util-helpers": {
      "root": "libs/shared/util/helpers",
      "sourceRoot": "libs/shared/util/helpers/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/shared/util/helpers/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/shared/util/helpers"],
          "options": {
            "jestConfig": "libs/shared/util/helpers/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "website-core": {
      "root": "libs/website/core",
      "sourceRoot": "libs/website/core/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/website/core/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/website/core"],
          "options": {
            "jestConfig": "libs/website/core/jest.config.js",
            "passWithNoTests": true
          }
        },
        "version": {
          "executor": "@jscutlery/semver:version",
          "options": {
            "syncVersions": false
          }
        }
      }
    },
    "website-feature-builder": {
      "root": "libs/website/feature/builder",
      "sourceRoot": "libs/website/feature/builder/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/website/feature/builder/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/website/feature/builder"],
          "options": {
            "jestConfig": "libs/website/feature/builder/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "website-feature-elements-material": {
      "root": "libs/website/feature/elements/material",
      "sourceRoot": "libs/website/feature/elements/material/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/website/feature/elements/material/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/website/feature/elements/material"],
          "options": {
            "jestConfig": "libs/website/feature/elements/material/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "website-feature-renderer": {
      "root": "libs/website/feature/renderer",
      "sourceRoot": "libs/website/feature/renderer/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/website/feature/renderer/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/website/feature/renderer"],
          "options": {
            "jestConfig": "libs/website/feature/renderer/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "www": {
      "root": "apps/www",
      "sourceRoot": "apps/www",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "root": "apps/www",
            "outputPath": "dist/apps/www"
          },
          "configurations": {
            "production": {}
          }
        },
        "serve": {
          "executor": "@nrwl/next:server",
          "options": {
            "buildTarget": "www:build",
            "dev": true
          },
          "configurations": {
            "production": {
              "buildTarget": "www:build:production",
              "dev": false
            }
          }
        },
        "export": {
          "executor": "@nrwl/next:export",
          "options": {
            "buildTarget": "www:build:production"
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/www"],
          "options": {
            "jestConfig": "apps/www/jest.config.js",
            "passWithNoTests": true
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/www/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "version": {
          "executor": "@jscutlery/semver:version",
          "options": {
            "syncVersions": false
          }
        }
      }
    },
    "www-e2e": {
      "root": "apps/www-e2e",
      "sourceRoot": "apps/www-e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "apps/www-e2e/cypress.json",
            "tsConfig": "apps/www-e2e/tsconfig.e2e.json",
            "devServerTarget": "www:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "www:serve:production"
            }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/www-e2e/**/*.{js,ts}"]
          }
        }
      }
    }
  }
}

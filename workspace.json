    "addons-ui-mui-bundle": {
      "root": "libs/addons/ui/mui-bundle",
      "sourceRoot": "libs/addons/ui/mui-bundle/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/addons/ui/mui-bundle/**/*.{ts,tsx,js,jsx}"]
          },
          "outputs": ["{options.outputFile}"]
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/addons/ui/mui-bundle"],
          "options": {
            "jestConfig": "libs/addons/ui/mui-bundle/jest.config.js",
            "passWithNoTests": true
          }
        }
      },
      "tags": ["scope:lib", "scope:lib:sdk", "scope:lib:sdk:extension"],
      "implicitDependencies": []
    },
    "console": {
      "root": "apps/console",
      "sourceRoot": "apps/console",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "root": "apps/console",
            "outputPath": "dist/apps/console"
          },
          "configurations": {
            "production": {}
          }
        },
        "serve": {
          "executor": "@nrwl/next:server",
          "options": {
            "buildTarget": "console:build",
            "dev": true
          },
          "configurations": {
            "production": {
              "buildTarget": "console:build:production",
              "dev": false
            }
          }
        },
        "export": {
          "executor": "@nrwl/next:export",
          "options": {
            "buildTarget": "console:build:production"
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/console"],
          "options": {
            "jestConfig": "apps/console/jest.config.js",
            "passWithNoTests": true
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/console/**/*.{ts,tsx,js,jsx}"]
          },
          "outputs": ["{options.outputFile}"]
        },
        "version": {
          "executor": "@jscutlery/semver:version",
          "options": {
            "syncVersions": false
          }
        }
      },
      "tags": ["scope:app", "scope:app:console"],
      "implicitDependencies": []
    },

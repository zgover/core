{
  "version": 2,
  "cli": {
    "defaultCollection": "@nrwl/next"
  },
  "defaultProject": "console",
  "generators": {
    "@nrwl/react": {
      "application": {
        "babel": true
      }
    },
    "@nrwl/next": {
      "application": {
        "style": "@emotion/styled",
        "linter": "eslint"
      }
    }
  },
  "projects": {
    "console": {
      "root": "apps/console",
      "sourceRoot": "apps/console",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "root": "apps/console",
            "outputPath": "dist/apps/console"
          },
          "configurations": {
            "production": {}
          }
        },
        "serve": {
          "executor": "@nrwl/next:server",
          "options": {
            "buildTarget": "console:build",
            "dev": true
          },
          "configurations": {
            "production": {
              "buildTarget": "console:build:production",
              "dev": false
            }
          }
        },
        "export": {
          "executor": "@nrwl/next:export",
          "options": {
            "buildTarget": "console:build:production"
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/console"],
          "options": {
            "jestConfig": "apps/console/jest.config.js",
            "passWithNoTests": true
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/console/**/*.{ts,tsx,js,jsx}"]
          }
        }
      }
    },
    "console-e2e": {
      "root": "apps/console-e2e",
      "sourceRoot": "apps/console-e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "apps/console-e2e/cypress.json",
            "tsConfig": "apps/console-e2e/tsconfig.e2e.json",
            "devServerTarget": "console:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "console:serve:production"
            }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/console-e2e/**/*.{js,ts}"]
          }
        }
      }
    },
    "ui-common": {
      "root": "libs/ui-common",
      "sourceRoot": "libs/ui-common/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/ui-common/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/ui-common"],
          "options": {
            "jestConfig": "libs/ui-common/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "tools": {
      "root": "libs/tools",
      "sourceRoot": "libs/tools/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/tools/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/tools"],
          "options": {
            "jestConfig": "libs/tools/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "mdi-icons": {
      "root": "libs/mdi-icons",
      "sourceRoot": "libs/mdi-icons/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/mdi-icons/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/mdi-icons"],
          "options": {
            "jestConfig": "libs/mdi-icons/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "website": {
      "root": "libs/website",
      "sourceRoot": "libs/website/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/website/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/website"],
          "options": {
            "jestConfig": "libs/website/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    }
  }
}

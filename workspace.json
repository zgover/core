            "production": {},
            "development": {}
          }
        },
        "serve": {
          "executor": "@nrwl/next:server",
          "options": {
            "buildTarget": "admin:build",
            "dev": true
          },
          "configurations": {
            "production": {
              "buildTarget": "admin:build:production",
              "dev": false
            },
            "development": {
              "buildTarget": "admin:build:development",
              "dev": true
            }
          },
          "defaultConfiguration": "development"

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    // Staff access is a Firebase custom claim set via
    // tools/scripts/set-staff-claim.mjs (Aglyn Admin Console, AGL-42).
    function isStaff() { return isSignedIn() && request.auth.token.staff == true; }
    // Staff RBAC (AGL-206): roles ride a second claim; a missing role
    // means 'super' so pre-RBAC staff keep full access (migration path).
    // support = read-only surfaces; billing = plan/entitlement writes;
    // super = everything including suspension and user management.
    function staffRole() {
      return request.auth.token.get('staffRole', 'super');
    }
    function isBillingStaff() {
      return isStaff() && (staffRole() == 'super' || staffRole() == 'billing');
    }
    function isSuperStaff() { return isStaff() && staffRole() == 'super'; }

    // ------------------------------------------------------------------
    // Organizations (AGL-233/235, docs/MULTI_TENANT_FIRESTORE.md): the
    // org is the tenant boundary. Authorization resolves from the single
    // membership doc read below — identical get()s within one evaluation
    // are billed once, so the helpers can share it freely.
    // ------------------------------------------------------------------
    match /orgs/{orgId} {
      function isOrgMember() {
        return isSignedIn() &&
          exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid));
      }
      function orgMember() {
        return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data;
      }
      function canManageOrg() {
        return isOrgMember() && orgMember().role in ['owner', 'admin'];
      }
      function orgNotSuspended() {
        return orgMember().get('orgSuspended', false) != true;
      }

      allow read: if isStaff() || isOrgMember();
      // Org creation/deletion and the slug/owner/billing keys are
      // Admin-SDK-only (org APIs, Stripe webhook, staff tooling), with
      // two staff exceptions mirroring the retired tenants rules
      // (AGL-206/238): super staff writes anything; billing staff writes
      // plan/entitlements but the key diff keeps suspension, erasure and
      // identity keys out of reach. Members with the admin role may
      // rename the org; nothing else is client-writable.
      allow create, delete: if false;
      // `enabledPlugins` is the runtime plugin switchboard, written ONLY by
      // the install API after entitlement + kill-switch checks (AGL-501) —
      // it must stay out of every client-writable branch, or an admin can
      // enable gated/paid plugins for free.
      allow update: if isSuperStaff() ||
        (isBillingStaff() &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(
            ['slug', 'ownerUid', 'hosts', 'enabledPlugins',
             'suspendedAt', 'suspendedReason', 'erasureRequestedAt'])) ||
        (canManageOrg() && orgNotSuspended() &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(
            ['slug', 'ownerUid', 'hosts', 'plan', 'entitlements',
             'enabledPlugins', 'seatAddons', 'stripeCustomerId', 'subscription',
             'suspendedAt', 'suspendedReason', 'erasureRequestedAt']));

      // The roster is visible to the whole org (names/emails are
      // denormalized for the team page); mutations go through the
      // membership API so the reverse index and host projections stay
      // consistent.
      match /members/{memberUid} {
        allow read: if isStaff() || isOrgMember();
        allow write: if false;
      }

      // Invites carry emails — readable by org managers only; the invited
      // account accepts through the API, never by writing here.
      match /invites/{inviteId} {
        allow read: if isStaff() || canManageOrg();
        allow write: if false;
      }

      // Custom roles (AGL-243): named permission sets members resolve
      // their own access from — member-readable, API-written only.
      match /roles/{roleId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if false;
      }

      // Monthly usage rollups (AGL-41) + the live API-request meter
      // (AGL-635): member-readable so the Billing page usage meters show real
      // numbers. Written only by the server — the report-usage cron and the
      // customer-API auth chokepoint via the Admin SDK, which bypasses rules.
      match /usage/{month} {
        allow read: if isStaff() || isOrgMember();
        allow write: if false;
      }
      match /apiUsage/{month} {
        allow read: if isStaff() || isOrgMember();
        allow write: if false;
      }

      // Per-plugin settings (AGL-428): overrides for a plugin's declared
      // config schema. Readers defensively coerce types (the doc is
      // manager-writable), so junk here can misconfigure only that
      // plugin, never break it.
      match /pluginSettings/{pluginId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if isStaff() || (canManageOrg() && orgNotSuspended());
      }

      // Org-shared data (AGL-237): datasets (records included), contacts
      // and segments are shared across every host in the org. Any member
      // reads; editors and up write; viewers stay read-only. Suspension
      // rides the member doc like org renames.
      function canWriteOrgData() {
        return isOrgMember() &&
          orgMember().role in ['owner', 'admin', 'editor'] &&
          orgNotSuspended();
      }
      // Dataset/record CREATES are API-only (AGL-473): the console route
      // enforces the dataStore entitlement and dataset/record quotas
      // server-side. Updates and deletes stay editor-writable — they
      // don't consume quota.
      match /datasets/{datasetId} {
        allow read: if isStaff() || isOrgMember();
        allow create: if isStaff();
        allow update, delete: if isStaff() || canWriteOrgData();
        match /records/{recordId} {
          allow read: if isStaff() || isOrgMember();
          allow create: if isStaff();
          allow update, delete: if isStaff() || canWriteOrgData();
        }
      }
      match /contacts/{contactId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if isStaff() || canWriteOrgData();
      }
      match /contactSegments/{segmentId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if isStaff() || canWriteOrgData();
      }

      // Email lists (AGL-254): static audiences shared across the org's
      // hosts; the enrollList automation step writes members server-side.
      match /lists/{listId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if isStaff() || canWriteOrgData();
        match /members/{memberId} {
          allow read: if isStaff() || isOrgMember();
          allow write: if isStaff() || canWriteOrgData();
        }
      }

      // Org media library (AGL-237, full DAM parity): shareable with any
      // host in the org. Storage objects stay API-managed (upload/delete
      // routes enforce quota), but editors mutate the metadata docs the
      // same way they do on a host's library (rename, folder moves).
      match /media/{mediaId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if isStaff() || canWriteOrgData();
      }
      match /mediaFolders/{folderId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if isStaff() || canWriteOrgData();
      }
      // Storage quota meter for the org library.
      match /counters/{counterId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if false;
      }

      // Org-tier plugin installs (AGL-237): pins that apply to every host
      // in the org; written only by the install API (entitlement + kill
      // switch checks live there).
      match /installs/{listingId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if false;
      }

      // Org activity log: mirrors hosts/{hostId}/activity, visible to any
      // member; written only by the org API routes (Admin SDK).
      match /activity/{entryId} {
        allow read: if isStaff() || isOrgMember();
        allow write: if false;
      }
    }

    // Workspace-subdomain resolution ({slug}.aglyn.com): public read so
    // the console can resolve a slug pre-auth; reservation is API-only.
    match /orgSlugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // Host → org resolver mirror, server-written beside host create.
    match /hostIndex/{hostId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Customer API keys (AGL-616). Secret material: only a SHA-256 hash of
    // the token is stored (doc id = hash). Deny ALL client access — minting,
    // listing (metadata only), verification, and revocation happen through
    // the Admin SDK. Clients never read this collection.
    match /apiKeys/{keyHash} {
      allow read, write: if false;
    }

    // REST API idempotency records (AGL-618): dedupe POSTs by Idempotency-Key.
    // Written and read by the Admin SDK only.
    match /apiIdempotency/{keyHash} {
      allow read, write: if false;
    }

    // Hosts and everything under them (content-hardening review,
    // 2026-07-07: tenant sites read through the Admin SDK, so no public
    // read). Access resolves through the org membership projection
    // `memberRoles` stamped on the host doc by the org APIs (AGL-233) —
    // one get, role-aware (admin/editor write, viewer read). The legacy
    // `admins` uid-map retired with the tenants collection (AGL-238).
    function hostMemberRole(hostId) {
      return get(/databases/$(database)/documents/hosts/$(hostId))
        .data.get('memberRoles', {}).get(request.auth.uid, null);
    }
    function isHostAdmin(hostId) {
      return isSignedIn() && hostMemberRole(hostId) != null;
    }
    function canWriteHostContent(hostId) {
      return isSignedIn() && hostMemberRole(hostId) in ['admin', 'editor'];
    }
    // Suspension write-block (AGL-210/238): a staff-suspended org keeps
    // read access but cannot mutate content. Fail-open when the org doc
    // is missing (pre-org hosts) so legacy data never locks up.
    function orgSuspendedById(orgId) {
      return orgId != null &&
        exists(/databases/$(database)/documents/orgs/$(orgId)) &&
        get(/databases/$(database)/documents/orgs/$(orgId))
          .data.get('suspendedAt', null) != null;
    }
    function hostOrgSuspended(hostId) {
      return orgSuspendedById(
        get(/databases/$(database)/documents/hosts/$(hostId))
          .data.get('orgId', null));
    }
    match /hosts/{hostId} {
      // Queries must be membership-constrained (the console filters on
      // memberRoles.{uid}), which these rules admit.
      allow read: if isStaff() || (isSignedIn() &&
        resource.data.get('memberRoles', {}).get(request.auth.uid, null) != null);
      // Creation moved fully server-side (AGL-233): /api/hosts/create
      // checks org role + quota + subdomain uniqueness with the Admin SDK.
      allow create: if false;
      // The host doc carries live directories (screens, layouts), so
      // editors update it too; deletion is admin-only. Editors must NOT be
      // able to rewrite the identity/projection keys: `memberRoles` is the
      // access list (self-escalation / add-outsider / lock-out-owner),
      // `orgId` gates suspension, `admins`/`hosts` are legacy/ownership, and
      // `subdomain` is the site's public address — a client write could take
      // a reserved name or collide with another org's site, making
      // subdomain->host resolution ambiguous (AGL-642). It goes through
      // /api/hosts/rename, which claims uniqueness transactionally.
      // Those keys are Admin-SDK-only (org APIs bypass rules); staff keep
      // full control for tooling.
      allow update: if isStaff() ||
        (canWriteHostContent(hostId) && !hostOrgSuspended(hostId) &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['memberRoles', 'orgId', 'admins', 'hosts', 'subdomain']));
      allow delete: if isStaff() ||
        (hostMemberRole(hostId) == 'admin' && !hostOrgSuspended(hostId));
      // Screen/layout DOC creates are API-only (AGL-473): /api/hosts/
      // resources enforces screensPerHost / sharedLayoutsPerHost (and the
      // owning org's suspension) server-side. Their `versions` (and any
      // other) subcollections stay editor-writable — not quota-governed.
      // These are carved OUT of the catch-all below (rules OR their allows,
      // so a dedicated deny can't win unless the catch-all stops matching).
      match /screens/{screenId} {
        allow read: if isStaff() || isHostAdmin(hostId);
        allow create: if isStaff();
        allow update, delete: if isStaff() ||
          (canWriteHostContent(hostId) && !hostOrgSuspended(hostId));
        match /{sub}/{document=**} {
          allow read: if isStaff() || isHostAdmin(hostId);
          allow write: if isStaff() ||
            (canWriteHostContent(hostId) && !hostOrgSuspended(hostId));
        }
      }
      match /layouts/{layoutId} {
        allow read: if isStaff() || isHostAdmin(hostId);
        allow create: if isStaff();
        allow update, delete: if isStaff() ||
          (canWriteHostContent(hostId) && !hostOrgSuspended(hostId));
        match /{sub}/{document=**} {
          allow read: if isStaff() || isHostAdmin(hostId);
          allow write: if isStaff() ||
            (canWriteHostContent(hostId) && !hostOrgSuspended(hostId));
        }
      }
      // Secret-/PII-bearing subcollections are carved out of the viewer-
      // readable catch-all below (AGL-502): `webhooks` docs hold an HMAC
      // signing secret + target URL, and `orders` hold customer PII/payment
      // data — reads are admin/editor only, never viewer. Writes fall through
      // to the catch-all (the console manages webhooks client-side; orders
      // are server-written), so only the READ is tightened here.
      match /webhooks/{webhookId} {
        allow read: if isStaff() || canWriteHostContent(hostId);
      }
      match /orders/{orderId} {
        allow read: if isStaff() || canWriteHostContent(hostId);
      }
      // The extra {subcollection} segment matters: a bare {document=**}
      // matches ZERO or more segments in rules v2, i.e. the host doc
      // itself too — which would let editors delete the host through
      // this write rule (caught by rules-tests, AGL-235).
      match /{subcollection}/{document=**} {
        allow read: if isStaff() ||
          (isHostAdmin(hostId) && !(subcollection in ['webhooks', 'orders']));
        // Quota-governed collections are created via /api/hosts/resources
        // ONLY (AGL-473) — the route enforces the per-plan quota (and the
        // feature entitlement, where paid) server-side. These flat
        // collections have no client-written subcollections, so denying
        // client `create` by name is safe. Screens/layouts also appear
        // here — their dedicated blocks above own create; excluding them
        // from update/delete too keeps this catch-all from re-granting.
        // `installs` (plugin pins) are create/update API-only (AGL-508): the
        // install route enforces entitlement + purchase + kill-switch before
        // writing the pin; only DELETE (uninstall) stays client-side, so
        // update/delete is split to allow the console's uninstall.
        allow create: if isStaff() ||
          ((canWriteHostContent(hostId) && !hostOrgSuspended(hostId)) &&
            !(subcollection in ['screens', 'layouts', 'variables',
              'functions', 'workflows', 'services', 'redirects',
              'locations', 'products', 'components', 'registers', 'installs']));
        allow update: if isStaff() ||
          ((canWriteHostContent(hostId) && !hostOrgSuspended(hostId)) &&
            !(subcollection in ['screens', 'layouts', 'installs']));
        allow delete: if isStaff() ||
          ((canWriteHostContent(hostId) && !hostOrgSuspended(hostId)) &&
            !(subcollection in ['screens', 'layouts']));
      }
    }

    // User profile docs (AGL-158): the console account page reads/writes
    // users/{uid}; the AGL-42 hardening dropped the blanket rule without
    // adding this match, which default-denied the collection.
    match /users/{userId} {
      allow read, write: if isStaff() ||
        (isSignedIn() && request.auth.uid == userId);

      // "My organizations" reverse index (AGL-233): API-maintained
      // beside the member docs; each user reads only their own.
      match /orgs/{orgId} {
        allow read: if isStaff() ||
          (isSignedIn() && request.auth.uid == userId);
        allow write: if false;
      }

      // In-app notifications (AGL-259): Admin-SDK-written fan-out; the
      // owner reads, marks read (update), and clears them.
      match /notifications/{notificationId} {
        allow read, update, delete: if isSignedIn() &&
          request.auth.uid == userId;
        allow create: if false;
      }
    }

    // Community marketplace (AGL-44). Profiles are public publisher pages
    // keyed by the publisher's uid; the owner or staff may write. Handle
    // and names are length-capped here since any owner writes client-side.
    match /profiles/{profileUid} {
      allow read: if true;
      // handle/displayName are length-capped since the owner writes client
      // side. `stripeAccountId` (payout destination) and `stripeChargesEnabled`
      // (payments-enabled gate) are set ONLY server-side after Connect
      // onboarding/KYC and are trusted by every checkout path — the client
      // must never set or change them (block on create, freeze on update).
      function profileFieldsValid() {
        return request.resource.data.handle is string &&
          request.resource.data.handle.size() >= 3 &&
          request.resource.data.handle.size() <= 30 &&
          request.resource.data.handle.matches('[a-z0-9][a-z0-9-]*') &&
          request.resource.data.displayName is string &&
          request.resource.data.displayName.size() <= 80;
      }
      function profileOwner() {
        return isStaff() || (isSignedIn() && request.auth.uid == profileUid);
      }
      allow create: if profileOwner() && profileFieldsValid() &&
        !request.resource.data.keys()
          .hasAny(['stripeAccountId', 'stripeChargesEnabled']);
      allow update: if profileOwner() && profileFieldsValid() &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['stripeAccountId', 'stripeChargesEnabled']);
    }

    // Org publisher identity (AGL-652). Publishing is ORG-ONLY: this is the
    // org's public marketplace presence, keyed by org id so authorization is
    // a plain role check with no ownership indirection. Public read — buyers
    // see who they are installing from. `profiles/{uid}` above stays as the
    // personal identity (the support forum renders author names from it) and
    // is no longer a publisher.
    match /publisherProfiles/{orgId} {
      allow read: if true;
      // The org rules' helpers are scoped to `match /orgs/{orgId}`, so this
      // block resolves membership itself. `exists()` first: reading `.data`
      // off a missing member doc errors rather than denying cleanly.
      function publisherManager() {
        return isStaff() || (isSignedIn() &&
          exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid))
            .data.role in ['owner', 'admin']);
      }
      function publisherFieldsValid() {
        return request.resource.data.handle is string &&
          request.resource.data.handle.size() >= 3 &&
          request.resource.data.handle.size() <= 30 &&
          request.resource.data.handle.matches('[a-z0-9][a-z0-9-]*') &&
          request.resource.data.displayName is string &&
          request.resource.data.displayName.size() <= 80;
      }
      // The payout keys decide who receives money — Connect route only.
      allow create: if publisherManager() && publisherFieldsValid() &&
        !request.resource.data.keys()
          .hasAny(['stripeAccountId', 'stripeChargesEnabled']);
      allow update: if publisherManager() && publisherFieldsValid() &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['stripeAccountId', 'stripeChargesEnabled']);
      allow delete: if isStaff();
    }

    // Handle uniqueness (AGL-652), mirroring orgSlugs: public read so a
    // handle resolves pre-auth, and claimed ONLY by the publish API inside a
    // transaction. Client-writable reservations would race, and whoever wrote
    // last would take another publisher's marketplace URL.
    match /publisherHandles/{handle} {
      allow read: if true;
      allow write: if false;
    }

    // Listings are public reads. Creates and version snapshots happen ONLY
    // through the publish API (Admin SDK, server-side sanitization) — no
    // client create. Owners may update/delete their own listing metadata
    // (unpublish via deletedAt); staff may moderate anything.
    match /communityListings/{listingId} {
      allow read: if true;
      allow create: if false;
      // Owners toggle metadata (deletedAt un/republish) client-side, but
      // must NOT touch server-managed fields (AGL-503): installCount is
      // incremented by the install API (ranking integrity), priceUsd gates
      // purchases, and profileId is the ownership key. The review verdict is
      // equally server-owned (AGL-651): `reviewStatus` decides both the
      // trust badge and whether a plugin is publicly browsable at all, so an
      // owner who could write it could self-promote to 'verified' and skip
      // staff review outright. Delete stays open to the owner; staff moderate
      // anything.
      allow update: if isStaff() ||
        (isSignedIn() && resource.data.profileId == request.auth.uid &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['installCount', 'priceUsd', 'profileId',
                     'reviewStatus', 'reviewedBy', 'reviewedAt',
                     'rejectionReason']));
      allow delete: if isStaff() ||
        (isSignedIn() && resource.data.profileId == request.auth.uid);
      // Version snapshots hold the actual (possibly paid) content — no
      // client reads; installs go through /api/community/install, which
      // checks the purchase record server-side (AGL-46).
      match /versions/{version} {
        allow read, write: if isStaff();
      }
      // Plugin version records hold the artifact sha256 + manifest (AGL-45).
      // Server-only, same as component versions: installs go through
      // /api/community/install-plugin, which checks entitlement + kill
      // switch and copies the pin into the host's installs.
      match /pluginVersions/{version} {
        allow read, write: if isStaff();
      }
    }

    // Plugin kill switch (AGL-45): loaders check this before executing a
    // pinned plugin, so it is a PUBLIC read; only staff (or the Admin SDK)
    // may write a revocation.
    match /revocations/{listingId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Marketplace purchase records (AGL-46): written only by the Stripe
    // webhook (Admin SDK). Buyers read their own purchases (install
    // gating); sellers read sales of their listings (revenue ledger).
    match /communityPurchases/{purchaseId} {
      allow read: if isStaff() || (isSignedIn() &&
        (resource.data.buyerUid == request.auth.uid ||
         resource.data.sellerUid == request.auth.uid));
      allow write: if false;
    }

    // Staff-only, append-only audit log of admin actions
    // ({ actorUid, action, target, before, after, at }).
    match /adminAudit/{entryId} {
      allow read, create: if isStaff();
      allow update, delete: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    // Staff access is a Firebase custom claim set via
    // tools/scripts/set-staff-claim.mjs (Aglyn Admin Console, AGL-42).
    function isStaff() { return isSignedIn() && request.auth.token.staff == true; }

    // Hosts and everything under them are scoped to the host's admins map
    // (content-hardening review, 2026-07-07): the previous any-authed access
    // let any signed-up account write other tenants' screens — a stored-XSS
    // and defacement vector once rich text landed. Tenant sites read through
    // the Admin SDK (bypasses rules), so no public read is needed here.
    function isHostAdmin(hostId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/hosts/$(hostId))
          .data.admins[request.auth.uid] == true;
    }
    match /hosts/{hostId} {
      // Queries must be admin-constrained (the console filters on
      // admins.{uid} == true), which this rule admits.
      allow read: if isStaff() || (isSignedIn() &&
        resource.data.admins[request.auth.uid] == true);
      allow create: if isSignedIn() &&
        request.resource.data.admins[request.auth.uid] == true;
      allow update, delete: if isStaff() ||
        (isSignedIn() && resource.data.admins[request.auth.uid] == true);
      match /{document=**} {
        allow read, write: if isStaff() || isHostAdmin(hostId);
      }
    }

    // User profile docs (AGL-158): the console account page reads/writes
    // users/{uid}; the AGL-42 hardening dropped the blanket rule without
    // adding this match, which default-denied the collection.
    match /users/{userId} {
      allow read, write: if isStaff() ||
        (isSignedIn() && request.auth.uid == userId);
    }

    // Tenant docs (billing v1: keyed by the owner's uid). Owners read their
    // own doc; clients never write plan/subscription — the Stripe webhook
    // and admin tooling write via the Admin SDK (which bypasses rules), and
    // staff may write from the admin console.
    match /tenants/{tenantId} {
      // Team members (AGL-127) read the owner tenant they belong to — the
      // console resolves plan/entitlements from the OWNER doc, keyed by the
      // member's uid in the owner's members subcollection.
      allow read: if isStaff() || (isSignedIn() &&
        (request.auth.uid == tenantId ||
          exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid))));
      allow write: if isStaff();
    }

    // Community marketplace (AGL-44). Profiles are public publisher pages;
    // the owner (tenants are keyed by uid) or staff may write. Handle and
    // names are length-capped here since any owner writes client-side.
    match /profiles/{tenantId} {
      allow read: if true;
      allow write: if (isStaff() ||
          (isSignedIn() && request.auth.uid == tenantId)) &&
        request.resource.data.handle is string &&
        request.resource.data.handle.size() >= 3 &&
        request.resource.data.handle.size() <= 30 &&
        request.resource.data.handle.matches('[a-z0-9][a-z0-9-]*') &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 80;
    }

    // Listings are public reads. Creates and version snapshots happen ONLY
    // through the publish API (Admin SDK, server-side sanitization) — no
    // client create. Owners may update/delete their own listing metadata
    // (unpublish via deletedAt); staff may moderate anything.
    match /communityListings/{listingId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if isStaff() ||
        (isSignedIn() && resource.data.profileId == request.auth.uid);
      // Version snapshots hold the actual (possibly paid) content — no
      // client reads; installs go through /api/community/install, which
      // checks the purchase record server-side (AGL-46).
      match /versions/{version} {
        allow read, write: if isStaff();
      }
    }

    // Marketplace purchase records (AGL-46): written only by the Stripe
    // webhook (Admin SDK). Buyers read their own purchases (install
    // gating); sellers read sales of their listings (revenue ledger).
    match /communityPurchases/{purchaseId} {
      allow read: if isStaff() || (isSignedIn() &&
        (resource.data.buyerUid == request.auth.uid ||
         resource.data.sellerUid == request.auth.uid));
      allow write: if false;
    }

    // Staff-only, append-only audit log of admin actions
    // ({ actorUid, action, target, before, after, at }).
    match /adminAudit/{entryId} {
      allow read, create: if isStaff();
      allow update, delete: if false;
    }
  }
}

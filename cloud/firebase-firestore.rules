rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    // Staff access is a Firebase custom claim set via
    // tools/scripts/set-staff-claim.mjs (Aglyn Admin Console, AGL-42).
    function isStaff() { return isSignedIn() && request.auth.token.staff == true; }
    // Staff RBAC (AGL-206): roles ride a second claim; a missing role
    // means 'super' so pre-RBAC staff keep full access (migration path).
    // support = read-only surfaces; billing = plan/entitlement writes;
    // super = everything including suspension and user management.
    function staffRole() {
      return request.auth.token.get('staffRole', 'super');
    }
    function isBillingStaff() {
      return isStaff() && (staffRole() == 'super' || staffRole() == 'billing');
    }
    function isSuperStaff() { return isStaff() && staffRole() == 'super'; }

    // ------------------------------------------------------------------
    // Organizations (AGL-233/235, docs/MULTI_TENANT_FIRESTORE.md): the
    // org is the tenant boundary. Authorization resolves from the single
    // membership doc read below — identical get()s within one evaluation
    // are billed once, so the helpers can share it freely.
    // ------------------------------------------------------------------
    match /orgs/{orgId} {
      function isOrgMember() {
        return isSignedIn() &&
          exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid));
      }
      function orgMember() {
        return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data;
      }
      function canManageOrg() {
        return isOrgMember() && orgMember().role in ['owner', 'admin'];
      }
      function orgNotSuspended() {
        return orgMember().get('orgSuspended', false) != true;
      }

      allow read: if isStaff() || isOrgMember();
      // Org creation/deletion and every billing/suspension/slug key are
      // Admin-SDK-only (org APIs, Stripe webhook, staff tooling). Members
      // with the admin role may rename the org; nothing else is
      // client-writable.
      allow create, delete: if false;
      allow update: if isSuperStaff() ||
        (canManageOrg() && orgNotSuspended() &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(
            ['slug', 'ownerUid', 'hosts', 'plan', 'entitlements',
             'seatAddons', 'stripeCustomerId', 'subscription',
             'suspendedAt', 'suspendedReason', 'erasureRequestedAt']));

      // The roster is visible to the whole org (names/emails are
      // denormalized for the team page); mutations go through the
      // membership API so the reverse index and host projections stay
      // consistent.
      match /members/{memberUid} {
        allow read: if isStaff() || isOrgMember();
        allow write: if false;
      }

      // Invites carry emails — readable by org managers only; the invited
      // account accepts through the API, never by writing here.
      match /invites/{inviteId} {
        allow read: if isStaff() || canManageOrg();
        allow write: if false;
      }

      // Org-shared resources (media, datasets, plugin installs) land here
      // in AGL-237; scoped rules ship with that move.
    }

    // Workspace-subdomain resolution ({slug}.aglyn.com): public read so
    // the console can resolve a slug pre-auth; reservation is API-only.
    match /orgSlugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // Host → org resolver mirror, server-written beside host create.
    match /hostIndex/{hostId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Hosts and everything under them (content-hardening review,
    // 2026-07-07: tenant sites read through the Admin SDK, so no public
    // read). Access now resolves through the org membership projection
    // `memberRoles` stamped on the host doc by the org APIs (AGL-233) —
    // one get, role-aware (admin/editor write, viewer read) — with the
    // legacy `admins` uid-map honored until every host is backfilled.
    function hostMemberRole(hostId) {
      return get(/databases/$(database)/documents/hosts/$(hostId))
        .data.get('memberRoles', {}).get(request.auth.uid, null);
    }
    function isHostAdmin(hostId) {
      return isSignedIn() &&
        (get(/databases/$(database)/documents/hosts/$(hostId))
          .data.get('admins', {}).get(request.auth.uid, false) == true ||
         hostMemberRole(hostId) != null);
    }
    function canWriteHostContent(hostId) {
      return isSignedIn() &&
        (get(/databases/$(database)/documents/hosts/$(hostId))
          .data.get('admins', {}).get(request.auth.uid, false) == true ||
         hostMemberRole(hostId) in ['admin', 'editor']);
    }
    // Suspension write-block (AGL-210): staff-suspended tenants keep read
    // access but cannot mutate content. Fail-open when the tenant doc is
    // missing (pre-billing hosts) so legacy data never locks up; billing
    // stays keyed to tenants/{uid} until AGL-237 re-keys it to orgs.
    function tenantSuspendedById(tenantId) {
      return tenantId != null &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)) &&
        get(/databases/$(database)/documents/tenants/$(tenantId))
          .data.get('suspendedAt', null) != null;
    }
    function hostTenantSuspended(hostId) {
      return tenantSuspendedById(
        get(/databases/$(database)/documents/hosts/$(hostId))
          .data.get('tenantId', null));
    }
    match /hosts/{hostId} {
      // Queries must be membership-constrained (the console filters on
      // admins.{uid} or memberRoles.{uid}), which these rules admit.
      allow read: if isStaff() || (isSignedIn() &&
        (resource.data.get('admins', {}).get(request.auth.uid, false) == true ||
         resource.data.get('memberRoles', {}).get(request.auth.uid, null) != null));
      // Creation moved fully server-side (AGL-233): /api/hosts/create
      // checks org role + quota + subdomain uniqueness with the Admin SDK.
      allow create: if false;
      // The host doc carries live directories (screens, layouts), so
      // editors update it too; deletion is admin-only.
      allow update: if isStaff() ||
        (canWriteHostContent(hostId) && !hostTenantSuspended(hostId));
      allow delete: if isStaff() ||
        ((resource.data.get('admins', {}).get(request.auth.uid, false) == true ||
          hostMemberRole(hostId) == 'admin') &&
         !hostTenantSuspended(hostId));
      // The extra {subcollection} segment matters: a bare {document=**}
      // matches ZERO or more segments in rules v2, i.e. the host doc
      // itself too — which would let editors delete the host through
      // this write rule (caught by rules-tests, AGL-235).
      match /{subcollection}/{document=**} {
        allow read: if isStaff() || isHostAdmin(hostId);
        allow write: if isStaff() ||
          (canWriteHostContent(hostId) && !hostTenantSuspended(hostId));
      }
    }

    // User profile docs (AGL-158): the console account page reads/writes
    // users/{uid}; the AGL-42 hardening dropped the blanket rule without
    // adding this match, which default-denied the collection.
    match /users/{userId} {
      allow read, write: if isStaff() ||
        (isSignedIn() && request.auth.uid == userId);

      // "My organizations" reverse index (AGL-233): API-maintained
      // beside the member docs; each user reads only their own.
      match /orgs/{orgId} {
        allow read: if isStaff() ||
          (isSignedIn() && request.auth.uid == userId);
        allow write: if false;
      }
    }

    // Tenant docs (billing v1: keyed by the owner's uid). Owners read their
    // own doc; clients never write plan/subscription — the Stripe webhook
    // and admin tooling write via the Admin SDK (which bypasses rules), and
    // staff may write from the admin console. Billing re-keys to orgs with
    // AGL-237; until then this collection stays authoritative for plans.
    match /tenants/{tenantId} {
      // Team members (AGL-127) read the owner tenant they belong to — the
      // console resolves plan/entitlements from the OWNER doc, keyed by the
      // member's uid in the owner's members subcollection.
      allow read: if isStaff() || (isSignedIn() &&
        (request.auth.uid == tenantId ||
          exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid))));
      // Plan/entitlement writes: billing or super. Suspension and erasure
      // flags are super-only (AGL-206) — checked by key diff so a billing
      // override save can't smuggle a suspension in.
      allow write: if isSuperStaff() ||
        (isBillingStaff() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['suspendedAt', 'suspendedReason', 'erasureRequestedAt']));
    }

    // Community marketplace (AGL-44). Profiles are public publisher pages;
    // the owner (tenants are keyed by uid) or staff may write. Handle and
    // names are length-capped here since any owner writes client-side.
    match /profiles/{tenantId} {
      allow read: if true;
      allow write: if (isStaff() ||
          (isSignedIn() && request.auth.uid == tenantId)) &&
        request.resource.data.handle is string &&
        request.resource.data.handle.size() >= 3 &&
        request.resource.data.handle.size() <= 30 &&
        request.resource.data.handle.matches('[a-z0-9][a-z0-9-]*') &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 80;
    }

    // Listings are public reads. Creates and version snapshots happen ONLY
    // through the publish API (Admin SDK, server-side sanitization) — no
    // client create. Owners may update/delete their own listing metadata
    // (unpublish via deletedAt); staff may moderate anything.
    match /communityListings/{listingId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if isStaff() ||
        (isSignedIn() && resource.data.profileId == request.auth.uid);
      // Version snapshots hold the actual (possibly paid) content — no
      // client reads; installs go through /api/community/install, which
      // checks the purchase record server-side (AGL-46).
      match /versions/{version} {
        allow read, write: if isStaff();
      }
      // Plugin version records hold the artifact sha256 + manifest (AGL-45).
      // Server-only, same as component versions: installs go through
      // /api/community/install-plugin, which checks entitlement + kill
      // switch and copies the pin into the host's installs.
      match /pluginVersions/{version} {
        allow read, write: if isStaff();
      }
    }

    // Plugin kill switch (AGL-45): loaders check this before executing a
    // pinned plugin, so it is a PUBLIC read; only staff (or the Admin SDK)
    // may write a revocation.
    match /revocations/{listingId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Marketplace purchase records (AGL-46): written only by the Stripe
    // webhook (Admin SDK). Buyers read their own purchases (install
    // gating); sellers read sales of their listings (revenue ledger).
    match /communityPurchases/{purchaseId} {
      allow read: if isStaff() || (isSignedIn() &&
        (resource.data.buyerUid == request.auth.uid ||
         resource.data.sellerUid == request.auth.uid));
      allow write: if false;
    }

    // Staff-only, append-only audit log of admin actions
    // ({ actorUid, action, target, before, after, at }).
    match /adminAudit/{entryId} {
      allow read, create: if isStaff();
      allow update, delete: if false;
    }
  }
}

{
  "$comment": "First-party plugin registry (AGL-417). THE single place that maps plugin ids to packages, register entry points, and API path prefixes. `tools/scripts/generate-plugin-manifests.mjs` turns this into the per-app generated loader manifests \u2014 the only files allowed to reference @aglyn/plugins-* outside libs/plugins. Ids must match FIRST_PARTY_PLUGINS in libs/aglyn plugin-manager/enabled-plugins.ts. register keys: site = canvas/site components (client barrel), console = ConsoleExtension (client barrel), tenantApi/consoleApi = API handlers (/server entry).",
  "plugins": [
    {
      "id": "mui",
      "package": "@aglyn/plugins-mui",
      "alwaysOn": true,
      "register": {
        "site": "registerMuiPlugin"
      }
    },
    {
      "id": "bookings",
      "package": "@aglyn/plugins-bookings",
      "register": {
        "site": "registerBookingsPlugin",
        "console": "registerBookingsConsole",
        "tenantApi": "registerBookingsApi",
        "consoleApi": "registerBookingsConsoleApi"
      },
      "apiPrefixes": [
        "bookings"
      ]
    },
    {
      "id": "commerce",
      "package": "@aglyn/plugins-commerce",
      "register": {
        "site": "registerCommercePlugin",
        "console": "registerCommerceConsole",
        "tenantApi": "registerCommerceApi",
        "consoleApi": "registerCommerceConsoleApi"
      },
      "apiPrefixes": [
        "commerce",
        "membership"
      ]
    },
    {
      "id": "community",
      "package": "@aglyn/plugins-community",
      "register": {
        "console": "registerCommunityConsole",
        "consoleApi": "registerCommunityConsoleApi"
      },
      "apiPrefixes": [
        "community"
      ]
    },
    {
      "id": "contacts",
      "package": "@aglyn/plugins-contacts",
      "register": {
        "console": "registerContactsConsole"
      }
    },
    {
      "id": "data",
      "package": "@aglyn/plugins-data",
      "register": {
        "console": "registerDataConsole"
      }
    },
    {
      "id": "email",
      "package": "@aglyn/plugins-email",
      "register": {
        "site": "registerEmailPlugin",
        "console": "registerEmailConsole",
        "tenantApi": "registerEmailApi"
      },
      "apiPrefixes": [
        "email"
      ]
    },
    {
      "id": "events-calendar",
      "package": "@aglyn/plugins-events-calendar",
      "register": {
        "site": "registerEventsCalendarPlugin",
        "console": "registerEventsCalendarConsole",
        "tenantApi": "registerEventsCalendarApi"
      },
      "apiPrefixes": [
        "events"
      ]
    },
    {
      "id": "inbox",
      "package": "@aglyn/plugins-inbox",
      "register": {
        "console": "registerInboxConsole"
      }
    },
    {
      "id": "logic",
      "package": "@aglyn/plugins-logic",
      "register": {
        "console": "registerLogicConsole"
      }
    },
    {
      "id": "marketing",
      "package": "@aglyn/plugins-marketing",
      "register": {
        "console": "registerMarketingConsole",
        "tenantApi": "registerMarketingApi",
        "consoleApi": "registerMarketingConsoleApi",
        "site": "registerMarketingPlugin"
      },
      "apiPrefixes": [
        "campaigns",
        "experiments"
      ]
    },
    {
      "id": "redirects",
      "package": "@aglyn/plugins-redirects",
      "register": {
        "console": "registerRedirectsConsole",
        "tenantApi": "registerRedirectsApi"
      }
    },
    {
      "id": "workflows",
      "package": "@aglyn/plugins-workflows",
      "register": {
        "console": "registerWorkflowsConsole",
        "tenantApi": "registerWorkflowsApi"
      },
      "apiPrefixes": [
        "hooks"
      ]
    }
  ]
}
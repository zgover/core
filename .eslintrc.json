{
  "root": true,
  "ignorePatterns": ["**/*"],
  "plugins": ["@nrwl/nx", "eslint-plugin-tsdoc"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@nrwl/nx/enforce-module-boundaries": [
          "error", {
            "enforceBuildableLibDependency": true,
            "allow": [],
            "depConstraints": [
              {
                "sourceTag": "scope:app",
                "onlyDependOnLibsWithTags": [
                  "scope:app",
                  "scope:lib"
                ]
              },
              {
                "sourceTag": "scope:app:www",
                "onlyDependOnLibsWithTags": [
                  "*"
                ]
              },
              {
                "sourceTag": "scope:lib",
                "onlyDependOnLibsWithTags": [
                  "scope:lib"
                ]
              },
              {
                "sourceTag": "scope:lib:shared",
                "onlyDependOnLibsWithTags": [
                  "scope:lib:shared"
                ]
              },
              {
                "sourceTag": "scope:lib:shared:util",
                "onlyDependOnLibsWithTags": [
                  "scope:lib:shared:util"
                ]
              },
              {
                "sourceTag": "scope:lib:shared:feature",
                "onlyDependOnLibsWithTags": [
                  "scope:lib:shared:feature"
                ]
              },
              {
                "sourceTag": "scope:lib:sdk",
                "onlyDependOnLibsWithTags": [
                  "scope:lib:sdk",
                  "scope:lib:shared"
                ]
              },
              {
                "sourceTag": "scope:lib:sdk:framework",
                "onlyDependOnLibsWithTags": [
                  "scope:lib:sdk:framework",
                  "scope:lib:shared:util",
                  "scope:lib:shared:feature"
                ]
              },
              {
                "sourceTag": "scope:lib:sdk:ui-besigner",
                "onlyDependOnLibsWithTags": [
                  "scope:lib:sdk:ui-besigner",
                  "scope:lib:sdk:framework",
                  "scope:lib:sdk:ui-renderer",
                  "scope:lib:shared"
                ]
              },
              {
                "sourceTag": "scope:lib:sdk:ui-renderer",
                "onlyDependOnLibsWithTags": [
                  "scope:lib:sdk:ui-renderer",
                  "scope:lib:sdk:framework",
                  "scope:lib:shared"
                ]
              },
              {
                "sourceTag": "scope:lib:sdk:extension",
                "onlyDependOnLibsWithTags": [
                  "scope:lib:sdk:extension",
                  "scope:lib"
                ]
              },
              {
                "sourceTag": "*",
                "onlyDependOnLibsWithTags": [
                  "*"
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "extends": ["plugin:@nrwl/nx/typescript"],
      "rules": {
        "@typescript-eslint/no-empty-function": "warn",
        "@typescript-eslint/no-empty-interface": "off",
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-namespace": "off",
        "@typescript-eslint/no-non-null-assertion": "off",
        "@typescript-eslint/no-unused-vars": "warn",
        "@typescript-eslint/no-var-requires": "off",
        "no-fallthrough": "off",
        "react-hooks/rules-of-hooks": "off",
        "tsdoc/syntax": ["warn", {}]
      }
    },
    {
      "files": ["*.js", "*.jsx"],
      "extends": ["plugin:@nrwl/nx/javascript"],
      "rules": {}
    },
    {
      "files": ["*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error", {
            "patterns": [
              "@mui/*/*/*",
              "!@mui/material/test-utils/*"
            ]
          }
        ],
        "react/no-children-prop": "off"
      }
    }
  ]
}

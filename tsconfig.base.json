{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "declarationMap": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "jsx": "preserve",
    "jsxImportSource": "react",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "noEmit": false,
    "noFallthroughCasesInSwitch": false,
    "noImplicitOverride": false,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "strictBindCallApply": true,
    "stripInternal": true,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "rootDir": ".",
    "paths": {
      "@/console/*": ["./libs/apps/console/*"],
      "@/tenant/*": ["./libs/apps/tenant/*"],
      "@/www/*": ["./libs/apps/www/*"],
      "@aglyn/aglyn": ["./libs/aglyn/src/index.ts"],
      "@aglyn/aglyn/server": ["./libs/aglyn/src/server.ts"],
      "@aglyn/aglyn-node-renderer": ["./libs/aglyn-node-renderer/src/index.ts"],
      "@aglyn/aglyn-node-renderer/*": ["./libs/aglyn-node-renderer/src/lib/*"],
      "@aglyn/aglyn/*": ["./libs/aglyn/src/lib/*"],
      "@aglyn/besigner": ["./libs/besigner/core/src/index.ts"],
      "@aglyn/besigner-ui": ["./libs/besigner/feature/designer/src/index.ts"],
      "@aglyn/besigner-ui/*": ["./libs/besigner/feature/designer/src/lib/*"],
      "@aglyn/besigner/*": ["./libs/besigner/core/src/lib/*"],
      "@aglyn/tenant-data-admin": ["./libs/tenant/data/admin/src/index.ts"],
      "@aglyn/tenant-data-admin/*": ["./libs/tenant/data/admin/src/lib/*"],
      "@aglyn/tenant-runtime": ["./libs/tenant/runtime/src/index.ts"],
      "@aglyn/tenant-runtime/*": ["./libs/tenant/runtime/src/lib/*"],
      "@aglyn/plugins-email": ["./libs/plugins/email/src/index.ts"],
      "@aglyn/plugins-email/*": ["./libs/plugins/email/src/lib/*"],
      "@aglyn/plugins-bookings": ["./libs/plugins/bookings/src/index.ts"],
      "@aglyn/plugins-bookings/*": ["./libs/plugins/bookings/src/lib/*"],

      "@aglyn/plugins-ui-mui": ["libs/plugins/ui/mui/src/index.ts"],
      "@aglyn/plugins-ui-mui/*": ["libs/plugins/ui/mui/src/lib/*"],
      "@aglyn/shared-data-enums": ["libs/shared/data/enums/src/index.ts"],

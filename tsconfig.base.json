{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "declarationMap": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "explainFiles": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "jsx": "preserve",
    "jsxImportSource": "@emotion/react",
    "lib": ["dom", "dom.iterable", "esnext"],
    "listFiles": true,
    "module": "esnext",
    "moduleResolution": "node",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitOverride": false,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "strictBindCallApply": true,
    "stripInternal": true,
    "target": "es2015",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@aglyn/addons-ui-mui-bundle": ["libs/addons/ui/mui-bundle/src/index.ts"],
      "@aglyn/core-data-besigner": ["libs/core/data/besigner/src/index.ts"],
      "@aglyn/core-data-framework": ["libs/core/data/framework/src/index.ts"],
      "@aglyn/core-data-tenancy": ["libs/core/data/tenancy/src/index.ts"],
      "@aglyn/core-feature-besigner": ["libs/core/feature/besigner/src/index.ts"],
      "@aglyn/core-feature-canvas-designer": ["libs/core/feature/canvas-designer/src/index.ts"],
      "@aglyn/core-feature-renderer": ["libs/core/feature/renderer/src/index.ts"],
      "@aglyn/core-feature-singleton": ["libs/core/feature/singleton/src/index.ts"],
      "@aglyn/shared-data-brand": ["libs/shared/data/brand/src/index.ts"],
      "@aglyn/shared-data-enums": ["libs/shared/data/enums/src/index.ts"],
      "@aglyn/shared-data-fbenums": ["libs/shared/data/fbenums/src/index.ts"],
      "@aglyn/shared-data-forms": ["libs/shared/data/forms/src/index.ts"],
      "@aglyn/shared-data-mdi": ["libs/shared/data/mdi/src/index.ts"],
      "@aglyn/shared-data-regex": ["libs/shared/data/regex/src/index.ts"],
      "@aglyn/shared-data-types": ["libs/shared/data/types/src/index.ts"],
      "@aglyn/shared-feature-fbclient": ["libs/shared/feature/fbclient/src/index.ts"],
      "@aglyn/shared-feature-fbserver": ["libs/shared/feature/fbserver/src/index.ts"],
      "@aglyn/shared-ui-jsx": ["libs/shared/ui/jsx/src/index.ts"],
      "@aglyn/shared-ui-jsx-forms": ["libs/shared/ui/jsx-forms/src/index.ts"],
      "@aglyn/shared-ui-mdi-jsx": ["libs/shared/ui/mdi-jsx/src/index.ts"],
      "@aglyn/shared-ui-next": ["libs/shared/ui/next/src/index.ts"],
      "@aglyn/shared-ui-snackstack": ["libs/shared/ui/snackstack/src/index.ts"],
      "@aglyn/shared-ui-theme": ["libs/shared/ui/theme/src/index.ts"],
      "@aglyn/shared-util-dom": ["libs/shared/util/dom/src/index.ts"],
      "@aglyn/shared-util-emitter": ["libs/shared/util/emitter/src/index.ts"],
      "@aglyn/shared-util-errors": ["libs/shared/util/errors/src/index.ts"],
      "@aglyn/shared-util-guards": ["libs/shared/util/guards/src/index.ts"],
      "@aglyn/shared-util-http": ["libs/shared/util/http/src/index.ts"],
      "@aglyn/shared-util-logger": ["libs/shared/util/logger/src/index.ts"],
      "@aglyn/shared-util-next": ["libs/shared/util/next/src/index.ts"],
      "@aglyn/shared-util-rest-api": ["libs/shared/util/rest-api/src/index.ts"],
      "@aglyn/shared-util-timestamp": ["libs/shared/util/timestamp/src/index.ts"],

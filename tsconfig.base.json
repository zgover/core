{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "declarationMap": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "jsx": "preserve",
    "jsxImportSource": "react",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2022",
    "noEmit": false,
    "noFallthroughCasesInSwitch": false,
    "noImplicitOverride": false,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "strictBindCallApply": true,
    "stripInternal": true,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/admin/*": ["libs/apps/admin/*"],
      "@/api/*": ["libs/apps/api/*"],
      "@/console/*": ["libs/apps/console/*"],
      "@/tenant/*": ["libs/apps/tenant/*"],
      "@/www/*": ["libs/apps/www/*"],
      "@aglyn/aglyn": ["libs/aglyn/src/index.ts"],
      "@aglyn/aglyn-node-renderer": ["libs/aglyn-node-renderer/src/index.ts"],
      "@aglyn/aglyn-node-renderer/*": ["libs/aglyn-node-renderer/src/lib/*"],
      "@aglyn/aglyn-plugin-mui": ["libs/aglyn-plugin-mui/src/index.ts"],
      "@aglyn/aglyn-plugin-mui/*": ["libs/aglyn-plugin-mui/src/lib/*"],
      "@aglyn/aglyn/*": ["libs/aglyn/src/lib/*"],
      "@aglyn/besigner": ["libs/aglyn-besigner/src/index.ts"],
      "@aglyn/besigner-data-app": ["libs/besigner/data/app/src/index.ts"],
      "@aglyn/besigner-data-app/*": ["libs/besigner/data/app/src/lib/*"],
      "@aglyn/besigner-feature-canvas-designer": ["libs/besigner/feature/canvas-designer/src/index.ts"],
      "@aglyn/besigner-feature-canvas-designer/*": ["libs/besigner/feature/canvas-designer/src/lib/*"],
      "@aglyn/besigner-json-editor": ["libs/besigner-json-editor/src/index.ts"],
      "@aglyn/besigner-json-editor/*": ["libs/besigner-json-editor/src/lib/*"],
      "@aglyn/besigner-ui": ["libs/aglyn-besigner-ui/src/index.ts"],
      "@aglyn/besigner-ui-box-styler": ["libs/besigner/ui/box-styler/src/index.ts"],
      "@aglyn/besigner-ui-box-styler/*": ["libs/besigner/ui/box-styler/src/lib/*"],
      "@aglyn/besigner-ui-color-picker": ["libs/besigner/ui/color-picker/src/index.ts"],
      "@aglyn/besigner-ui-color-picker/*": ["libs/besigner/ui/color-picker/src/lib/*"],
      "@aglyn/besigner-ui-form-fields": ["libs/besigner/ui/form-fields/src/index.ts"],
      "@aglyn/besigner-ui-form-fields/*": ["libs/besigner/ui/form-fields/src/lib/*"],
      "@aglyn/besigner-ui/*": ["libs/aglyn-besigner-ui/src/lib/*"],
      "@aglyn/besigner/*": ["libs/aglyn-besigner/src/lib/*"],
      "@aglyn/core-data-admin": ["libs/core/data/admin/src/index.ts"],
      "@aglyn/core-data-admin/*": ["libs/core/data/admin/src/lib/*"],
      "@aglyn/core-data-app": ["libs/core/data/app/src/index.ts"],
      "@aglyn/core-data-app/*": ["libs/core/data/app/src/lib/*"],
      "@aglyn/core-data-foundation": ["libs/core/data/foundation/src/index.ts"],
      "@aglyn/core-data-foundation/*": ["libs/core/data/foundation/src/lib/*"],
      "@aglyn/core-feature-renderer": ["libs/core/feature/renderer/src/index.ts"],

{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "declarationMap": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "explainFiles": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "listFiles": true,
    "jsx": "preserve",
    "jsxImportSource": "@emotion/react",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2016",
    "noEmit": false,
    "noFallthroughCasesInSwitch": false,
    "noImplicitOverride": false,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "strictBindCallApply": true,
    "stripInternal": true,
    "strictNullChecks": false,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/admin/*": ["libs/apps/admin/*"],
      "@/api/*": ["libs/apps/api/*"],
      "@/console/*": ["libs/apps/console/*"],
      "@/tenant/*": ["libs/apps/tenant/*"],
      "@/www/*": ["libs/apps/www/*"],
      "@aglyn/aglyn": ["libs/aglyn/src/index.ts"],
      "@aglyn/aglyn-plugin-mui": ["libs/aglyn-plugin-mui/src/index.ts"],
      "@aglyn/besigner-data-app": ["libs/besigner/data/app/src/index.ts"],
      "@aglyn/besigner-data-app/*": ["libs/besigner/data/app/src/lib/*"],
      "@aglyn/besigner-feature-app": ["libs/besigner/feature/app/src/index.ts"],
      "@aglyn/besigner-feature-app/*": ["libs/besigner/feature/app/src/lib/*"],
      "@aglyn/besigner-feature-canvas-designer": ["libs/besigner/feature/canvas-designer/src/index.ts"],
      "@aglyn/besigner-feature-canvas-designer/*": ["libs/besigner/feature/canvas-designer/src/lib/*"],
      "@aglyn/besigner-ui-box-styler": ["libs/besigner/ui/box-styler/src/index.ts"],
      "@aglyn/besigner-ui-color-picker": ["libs/besigner/ui/color-picker/src/index.ts"],
      "@aglyn/besigner-ui-color-picker/*": ["libs/besigner/ui/color-picker/src/lib/*"],
      "@aglyn/core-data-admin": ["libs/core/data/admin/src/index.ts"],
      "@aglyn/core-data-admin/*": ["libs/core/data/admin/src/lib/*"],
      "@aglyn/core-data-app": ["libs/core/data/app/src/index.ts"],
      "@aglyn/core-data-app/*": ["libs/core/data/app/src/lib/*"],
      "@aglyn/core-data-foundation": ["libs/core/data/foundation/src/index.ts"],
      "@aglyn/core-data-foundation/*": ["libs/core/data/foundation/src/lib/*"],
      "@aglyn/core-feature-renderer": ["libs/core/feature/renderer/src/index.ts"],
      "@aglyn/core-feature-renderer/*": ["libs/core/feature/renderer/src/lib/*"],
      "@aglyn/core-feature-singleton": ["libs/core/feature/singleton/src/index.ts"],
      "@aglyn/core-feature-singleton/*": ["libs/core/feature/singleton/src/lib/*"],
      "@aglyn/core-ui-renderer": ["libs/core/ui/renderer/src/index.ts"],

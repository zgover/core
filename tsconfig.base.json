{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strictBindCallApply": true,
    "baseUrl": ".",
    "paths": {
      "@aglyn/shared/data/mdi": ["libs/shared/data/mdi/src/index.ts"],
      "@aglyn/shared/ui/react": ["libs/shared/ui/react/src/index.ts"],
      "@aglyn/shared/util/helpers": ["libs/shared/util/helpers/src/index.ts"],
      "@aglyn/website/core": ["libs/website/core/src/index.ts"],
      "@aglyn/website/feature/react-renderer": ["libs/website/feature/react-renderer/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}

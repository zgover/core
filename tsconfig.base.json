{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "declarationMap": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "explainFiles": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "jsx": "preserve",
    "jsxImportSource": "@emotion/react",
    "lib": ["dom", "dom.iterable", "esnext"],
    "listFiles": true,
    "module": "esnext",
    "moduleResolution": "node",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitOverride": false,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "strictBindCallApply": true,
    "stripInternal": true,
    "strictNullChecks": false,
    "target": "es2015",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@aglyn/besigner-data-app": ["libs/besigner/data/app/src/index.ts"],
      "@aglyn/besigner-feature-app": ["libs/besigner/feature/app/src/index.ts"],
      "@aglyn/besigner-feature-canvas-designer": [
        "libs/besigner/feature/canvas-designer/src/index.ts"
      ],
      "@aglyn/core-data-admin": ["libs/core/data/admin/src/index.ts"],
      "@aglyn/core-data-app": ["libs/core/data/app/src/index.ts"],
      "@aglyn/core-data-foundation": ["libs/core/data/foundation/src/index.ts"],
      "@aglyn/core-feature-renderer": [
        "libs/core/feature/renderer/src/index.ts"
      ],
      "@aglyn/core-feature-singleton": [
        "libs/core/feature/singleton/src/index.ts"
      ],
      "@aglyn/core-ui-renderer": ["libs/core/ui/renderer/src/index.ts"],
      "@aglyn/db-data-tenants": ["libs/db/data/tenants/src/index.ts"],
      "@aglyn/plugins-ui-mui": ["libs/plugins/ui/mui/src/index.ts"],
      "@aglyn/shared-data-brand": ["libs/shared/data/brand/src/index.ts"],
      "@aglyn/shared-data-enums": ["libs/shared/data/enums/src/index.ts"],
      "@aglyn/shared-data-fbenums": ["libs/shared/data/fbenums/src/index.ts"],
      "@aglyn/shared-data-forms": ["libs/shared/data/forms/src/index.ts"],
      "@aglyn/shared-data-mdi": ["libs/shared/data/mdi/src/index.ts"],
      "@aglyn/shared-data-regex": ["libs/shared/data/regex/src/index.ts"],
      "@aglyn/shared-data-types": ["libs/shared/data/types/src/index.ts"],
      "@aglyn/shared-feature-fbserver": [
        "libs/shared/feature/fbserver/src/index.ts"
      ],
      "@aglyn/shared-ui-color-picker": [
        "libs/shared/ui/color-picker/src/index.ts"
      ],
      "@aglyn/shared-ui-jsx": ["libs/shared/ui/jsx/src/index.ts"],

      "@aglyn/shared-ui-jsx": ["libs/shared/ui/jsx/src/index.ts"],
      "@aglyn/shared-ui-jsx-forms": ["libs/shared/ui/jsx-forms/src/index.ts"],
      "@aglyn/shared-ui-jsx-forms/*": ["libs/shared/ui/jsx-forms/src/lib/*"],
      "@aglyn/shared-ui-jsx/*": ["libs/shared/ui/jsx/src/lib/*"],
      "@aglyn/shared-ui-next": ["libs/shared/ui/next/src/index.ts"],
      "@aglyn/shared-ui-next/*": ["libs/shared/ui/next/src/lib/*"],
      "@aglyn/shared-ui-snackstack": ["libs/shared/ui/snackstack/src/index.ts"],
      "@aglyn/shared-ui-snackstack/*": ["libs/shared/ui/snackstack/src/lib/*"],
      "@aglyn/shared-ui-theme": ["libs/shared/ui/theme/src/index.ts"],
      "@aglyn/shared-ui-theme/*": ["libs/shared/ui/theme/src/lib/*"],
      "@aglyn/shared-util-dom": ["libs/shared/util/dom/src/index.ts"],
      "@aglyn/shared-util-dom/*": ["libs/shared/util/dom/src/lib/*"],
      "@aglyn/shared-util-emitter": ["libs/shared/util/emitter/src/index.ts"],
      "@aglyn/shared-util-emitter/*": ["libs/shared/util/emitter/src/lib/*"],
      "@aglyn/shared-util-errors": ["libs/shared/util/errors/src/index.ts"],
      "@aglyn/shared-util-errors/*": ["libs/shared/util/errors/src/lib/*"],
      "@aglyn/shared-util-fbclient": ["libs/shared/util/fbclient/src/index.ts"],
      "@aglyn/shared-util-fbclient/*": ["libs/shared/util/fbclient/src/lib/*"],
      "@aglyn/shared-util-http": ["libs/shared/util/http/src/index.ts"],
      "@aglyn/shared-util-http/*": ["libs/shared/util/http/src/lib/*"],
      "@aglyn/shared-util-logger": ["libs/shared/util/logger/src/index.ts"],
      "@aglyn/shared-util-logger/*": ["libs/shared/util/logger/src/lib/*"],
      "@aglyn/shared-util-next": ["libs/shared/util/next/src/index.ts"],
      "@aglyn/shared-util-next/*": ["libs/shared/util/next/src/lib/*"],
      "@aglyn/shared-util-rest-api": ["libs/shared/util/rest-api/src/index.ts"],
      "@aglyn/shared-util-rest-api/*": ["libs/shared/util/rest-api/src/lib/*"],
      "@aglyn/shared-util-timestamp": ["libs/shared/util/timestamp/src/index.ts"],
      "@aglyn/shared-util-timestamp/*": ["libs/shared/util/timestamp/src/lib/*"],
      "@aglyn/shared-util-tools": ["libs/shared/util/tools/src/index.ts"],
      "@aglyn/shared-util-tools/*": ["libs/shared/util/tools/src/lib/*"],
      "@aglyn/shared-util-vendor": ["libs/shared/util/vendor/src/index.ts"],
      "@aglyn/shared-util-vendor/*": ["libs/shared/util/vendor/src/lib/*"],
      "@aglyn/tenant-feature-instance": ["libs/tenant/feature/instance/src/index.ts"],
      "@aglyn/tenant-feature-instance/*": ["libs/tenant/feature/instance/src/lib/*"]
    },
    "typeRoots": ["types", "node_modules/@types"],
    "types": ["@tshelpers", "node"]
  },
  "exclude": ["node_modules", "tmp", "**/generated"]
}

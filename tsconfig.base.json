      "@aglyn/shared-data-forms": ["libs/shared/data/forms/src/index.ts"],
      "@aglyn/shared-data-forms/*": ["libs/shared/data/forms/src/lib/*"],
      "@aglyn/shared-data-mdi": ["libs/shared/data/mdi/src/index.ts"],
      "@aglyn/shared-data-mdi/*": ["libs/shared/data/mdi/src/lib/*"],
      "@aglyn/shared-data-regex": ["libs/shared/data/regex/src/index.ts"],
      "@aglyn/shared-data-regex/*": ["libs/shared/data/regex/src/lib/*"],
      "@aglyn/shared-data-types": ["libs/shared/data/types/src/index.ts"],
      "@aglyn/shared-data-types/*": ["libs/shared/data/types/src/lib/*"],
      "@aglyn/shared-feature-fbserver": ["libs/shared/feature/fbserver/src/index.ts"],
      "@aglyn/shared-feature-fbserver/*": ["libs/shared/feature/fbserver/src/lib/*"],
      "@aglyn/shared-svg-icons": ["libs/shared/svg-icons/svg-icons/src/index.ts"],

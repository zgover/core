      "@aglyn/plugins-marketing": ["./libs/plugins/marketing/src/index.ts"],
      "@aglyn/plugins-marketing/*": ["./libs/plugins/marketing/src/lib/*"],
      "@aglyn/plugins-commerce": ["./libs/plugins/commerce/src/index.ts"],

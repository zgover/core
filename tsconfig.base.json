{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strictBindCallApply": true,
    "baseUrl": ".",
    "paths": {
      "@aglyn/shared/data/mdi": ["libs/shared/data/mdi/src/index.ts"],
      "@aglyn/shared/ui/react": ["libs/shared/ui/react/src/index.ts"],
      "@aglyn/shared/ui/themes": ["libs/shared/ui/themes/src/index.ts"],
      "@aglyn/shared/util/helpers": ["libs/shared/util/helpers/src/index.ts"],
      "@aglyn/shared/util/logger": ["libs/shared/util/logger/src/index.ts"],
      "@aglyn/website/core": ["libs/website/core/src/index.ts"],
      "@aglyn/website/feature/builder": ["libs/website/feature/builder/src/index.ts"],
      "@aglyn/website/feature/plugin/material": [
        "libs/website/feature/plugin/material/src/index.ts"
      ],
      "@aglyn/website/feature/renderer": ["libs/website/feature/renderer/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}

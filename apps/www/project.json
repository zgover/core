{
  "name": "www",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/www",
  "projectType": "application",
  "tags": ["scope:app", "scope:public"],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "cache": false,
      "options": {
        "outputPath": "dist/apps/www"
      },
      "configurations": {
        "production": {
          "webpack": true
        },
        "development": {
          "outputPath": "apps/www"
        }
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "www:build",
        "dev": true,
        "port": 4100
      },
      "configurations": {
        "production": {
          "buildTarget": "www:build:production",
          "dev": false
        },
        "development": {
          "buildTarget": "www:build:development",
          "dev": true
        }
      }
    },
    "export": {
      "executor": "@nx/next:export",
      "options": {
        "buildTarget": "www:build:production"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/www"],
      "options": {
        "jestConfig": "apps/www/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "syncVersions": false
      }
    }
  }
}

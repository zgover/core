# General
PORT=4100
HOSTNAME=localhost
HOST=$HOSTNAME:$PORT
HOST_URL=http://$HOST

# HTTP
CSRF_SECRET="fehf54kt65nio6k3$#%$GFD76uj76jyt4f44378975768j6#@$%%$"

# Node
NODE_ENV=development
NODE_LOG=logs/node-debug.development.log
NODE_OPTIONS="--max-old-space-size=8192"

# Nx
NX_VERBOSE_LOGGING=true
NX_PERF_LOGGING=false

# Next
NEXT_ANALYZE_BUNDLE=false

# Aglyn Nextjs.config.js build
ANALYZE_STATS_ENABLED=false

# Firebase PUBLIC (general/client+server)
NEXT_PUBLIC_FIREBASE_PUBLIC_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase PRIVATE (admin/server)
FIREBASE_TYPE=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=

# Firebase EMULATE (local/test)
NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOSTNAME=$HOSTNAME
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=$FIRESTORE_EMULATOR_HOSTNAME:$FIRESTORE_EMULATOR_PORT
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOSTNAME=$HOSTNAME
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=$FIREBASE_AUTH_EMULATOR_HOSTNAME:$FIREBASE_AUTH_EMULATOR_PORT
NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_PORT=9199
NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_HOSTNAME=$HOSTNAME
NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_HOST=$FIREBASE_STORAGE_EMULATOR_HOSTNAME:$FIREBASE_STORAGE_EMULATOR_PORT
NEXT_PUBLIC_FIREBASE_DATABASE_EMULATOR_PORT=9000
NEXT_PUBLIC_FIREBASE_DATABASE_EMULATOR_HOSTNAME=$HOSTNAME
NEXT_PUBLIC_FIREBASE_DATABASE_EMULATOR_HOST=$FIREBASE_DATABASE_EMULATOR_HOSTNAME:$FIREBASE_DATABASE_EMULATOR_PORT
#GCLOUD_PROJECT=aglyn-app

# reCAPTCHA v3
NEXT_PUBLIC_RECPATCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# Firebase APP CHECK
APP_CHECK_DEBUG_TOKEN_FROM_CI=
APP_CHECK_DEBUG_TOKEN_FROM_CONSOLE=

# Node
NODE_ENV=development
NODE_LOG=logs/node-debug.development.log
NODE_OPTIONS="--trace-warnings"

# General
#PROTOCOL=http:
#HOSTNAME=localhost
#HOST=$HOSTNAME:$PORT
#HOST_URL=$PROTOCOL//$HOST

# Aglyn
#AGLYN_PORT=443
#AGLYN_PROTOCOL=https:
AGLYN_HOSTNAME=aglyn.io
AGLYN_APP_HOSTNAME=aglyn.app
#AGLYN_HOST=$AGLYN_HOSTNAME:$AGLYN_PORT
#AGLYN_URL=$AGLYN_PROTOCOL//$AGLYN_HOST
#AGLYN_TENANT_HOST_ID=myhost-1
#AGLYN_TENANT_HOST_HOSTNAME=$AGLYN_TENANT_HOST_ID.$AGLYN_HOSTNAME
#AGLYN_TENANT_HOST_HOST=$AGLYN_TENANT_HOST_ID.$AGLYN_HOST
#AGLYN_TENANT_HOST_URL=$AGLYN_PROTOCOL//$AGLYN_TENANT_HOST_HOST
#AGLYN_TENANT_HOST_CNAME=
#AGLYN_TENANT_PRIVATE_KEY=
#AGLYN_TENANT_PUBLIC_KEY=

# Nx
NX_VERBOSE_LOGGING=true
NX_PERF_LOGGING=false

# Mandatory next-auth URL for localhost
NEXTAUTH_URL=http://app.localhost:4500

# Next
ANALYZE_STATS_ENABLED=false
NEXT_ANALYZE_BUNDLE=false

# Firebase web config (public identifiers, safe to expose)
NEXT_PUBLIC_FIREBASE_PUBLIC_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=aglyn-main
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# NEXT_PUBLIC_FIREBASE_AUTH_HANDLER_HOST=

# Firebase Admin service account (SERVER-ONLY) — storefront serves media and
# runs commerce/plugin handlers via the Admin SDK. PRIVATE_KEY keeps literal "\n".
FIREBASE_PROJECT_ID=aglyn-main
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n…\n-----END PRIVATE KEY-----\n"

# Plugin platform
NEXT_PUBLIC_PLUGIN_ORIGIN=
NEXT_PUBLIC_PLUGIN_TRUST_PUBLIC_KEY=
PLUGIN_ARTIFACTS_BASE=
# Per-deployment plugin-jobs cron secret (/api/plugins/run-jobs). openssl rand -hex 32.
PLUGIN_JOBS_SECRET=
# Server-side realm plugin execution — default OFF; only enable with an explicit
# allowlist AND the trust public key configured.
# PLUGIN_REMOTE_SERVER=enabled
# PLUGIN_REMOTE_SERVER_BUNDLES=listingId@1.0.0
# Dev-only unverified plugin loop (AGL-516): both must be set to activate.
# NEXT_PUBLIC_PLUGIN_DEV=enabled
# NEXT_PUBLIC_PLUGIN_DEV_BUNDLES=my-plugin=http://localhost:5173/plugin.bundle.mjs

# Commerce (SERVER-ONLY)
# Signs the download + supplier tokens the storefront issues (AGL-509).
# Required — the commerce server code FAILS CLOSED if this is unset. Use a
# strong random value (e.g. `openssl rand -hex 32`) and set the SAME value in
# the console deployment: its Stripe webhook mints download links that this
# tenant app verifies, so the two must share the secret.
TOKEN_SIGNING_SECRET=
# Signs the storefront member session cookie (commerce). openssl rand -hex 32.
MEMBER_SESSION_SECRET=
# Stripe for storefront checkout/portal (the console holds the webhook secret).
STRIPE_SECRET_KEY=sk_test_...

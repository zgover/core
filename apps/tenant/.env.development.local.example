# Node
NODE_ENV=development
NODE_LOG=logs/node-debug.development.log
NODE_OPTIONS="--trace-warnings"

# General
#PROTOCOL=http:
#HOSTNAME=localhost
#HOST=$HOSTNAME:$PORT
#HOST_URL=$PROTOCOL//$HOST

# Aglyn
#AGLYN_PORT=443
#AGLYN_PROTOCOL=https:
AGLYN_HOSTNAME=aglyn.io
AGLYN_APP_HOSTNAME=aglyn.app
#AGLYN_HOST=$AGLYN_HOSTNAME:$AGLYN_PORT
#AGLYN_URL=$AGLYN_PROTOCOL//$AGLYN_HOST
#AGLYN_TENANT_HOST_ID=myhost-1
#AGLYN_TENANT_HOST_HOSTNAME=$AGLYN_TENANT_HOST_ID.$AGLYN_HOSTNAME
#AGLYN_TENANT_HOST_HOST=$AGLYN_TENANT_HOST_ID.$AGLYN_HOST
#AGLYN_TENANT_HOST_URL=$AGLYN_PROTOCOL//$AGLYN_TENANT_HOST_HOST
#AGLYN_TENANT_HOST_CNAME=
#AGLYN_TENANT_PRIVATE_KEY=
#AGLYN_TENANT_PUBLIC_KEY=

# Nx
NX_VERBOSE_LOGGING=true
NX_PERF_LOGGING=false

# Mandatory next-auth URL for localhost
NEXTAUTH_URL=http://app.localhost:4500

# Next
ANALYZE_STATS_ENABLED=false
NEXT_ANALYZE_BUNDLE=false

# Commerce (digital downloads / supplier tokens)
# Signs the download + supplier tokens the storefront issues (AGL-509).
# Required — the commerce server code FAILS CLOSED if this is unset. Use a
# strong random value (e.g. `openssl rand -hex 32`) and set the SAME value in
# the console deployment: its Stripe webhook mints download links that this
# tenant app verifies, so the two must share the secret. Server-only — never
# prefix with NEXT_PUBLIC_.
TOKEN_SIGNING_SECRET=

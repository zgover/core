{
  "name": "tenant",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/tenant",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "root": "apps/tenant",
        "outputPath": "dist/apps/tenant"
      },
      "configurations": {
        "production": {},
        "development": {
          "outputPath": "apps/tenant"
        }
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "options": {
        "buildTarget": "tenant:build",
        "dev": true,
        "port": 4500
      },
      "configurations": {
        "production": {
          "buildTarget": "tenant:build:production",
          "dev": false
        },
        "development": {
          "buildTarget": "tenant:build:development",
          "dev": true
        }
      },
      "defaultConfiguration": "development"
    },
    "export": {
      "executor": "@nx/next:export",
      "options": {
        "buildTarget": "tenant:build:production"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/tenant"],
      "options": {
        "jestConfig": "apps/tenant/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/tenant/**/*.{ts,tsx,js,jsx}"]
      }
    }
  },
  "tags": ["scope:app", "scope:public"]
}

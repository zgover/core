{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "sourceMap": false,
    "outDir": "../../dist/out-tsc",
    "allowJs": true,
    "types": ["@tshelpers", "node", "@jsx"]
  },
  // Cypress ships its own types (no @types/cypress); with explicit typeRoots,
  // TS 7 no longer resolves "types" entries from regular packages.
  "files": ["../../node_modules/cypress/types/index.d.ts"],
  "include": ["src/**/*.ts", "src/**/*.js"]
}

# apps/docs — the Docusaurus documentation site. It builds from static content
# and needs NO application secrets or Firebase config. This file exists so the
# setup story is consistent across apps; add vars here only if the docs site
# later integrates a keyed service (e.g. Algolia DocSearch).
#
# Example (only if/when Algolia search is enabled):
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=   # the SEARCH-only key, safe to expose

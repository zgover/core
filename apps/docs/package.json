    "@easyops-cn/docusaurus-search-local": "^0.52.1",
    "@fontsource/roboto": "^5.1.1",
    "@fontsource/roboto-mono": "^5.1.1",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.1.1",

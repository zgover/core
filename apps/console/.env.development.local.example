# apps/console — the workspace/admin app. Copy to `.env.development.local` and
# fill in. NEXT_PUBLIC_* are bundled into client JS (safe to expose); everything
# else is SERVER-ONLY — never prefix a secret with NEXT_PUBLIC_.
#
# TO SMOKE-TEST A PRODUCTION BUILD LOCALLY, copy this to
# `.env.production.local` as well:
#
#   cp apps/console/.env.development.local apps/console/.env.production.local
#   npx nx build console && npx nx serve console --configuration=production
#
# Next only reads `.env.development.local` when NODE_ENV=development, so a
# production build otherwise inlines `undefined` for every NEXT_PUBLIC_* and
# every authenticated page dies with `auth/invalid-api-key` — with nothing
# logged server-side (AGL-791). Both files are gitignored.

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Firebase web config (public identifiers, safe to expose) ──────────────────
NEXT_PUBLIC_FIREBASE_PUBLIC_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=aglyn-main
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin service account (SERVER-ONLY) ──────────────────────────────
# Powers the API routes (verifyIdToken, Firestore/Storage Admin SDK). Same
# service account as the root .env; PRIVATE_KEY keeps literal "\n".
FIREBASE_PROJECT_ID=aglyn-main
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n…\n-----END PRIVATE KEY-----\n"

# ── App identity ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_WORKSPACE_DOMAIN=aglyn.com
NEXT_PUBLIC_CONSOLE_URL=https://app.aglyn.com
# Idle-logout window (AGL-464); blank disables.
NEXT_PUBLIC_AUTH_IDLE_TIMEOUT_MINUTES=

# ── Stripe (billing + commerce; SERVER-ONLY) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Test-mode webhook endpoint secret (AGL-547) — fallback so platform-webhook
# fulfillment works for test-mode tenant checkouts.
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_METER_EVENT_NAME=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_BUSINESS_YEARLY=
STRIPE_PRICE_ADVANCED=
STRIPE_PRICE_ADVANCED_YEARLY=
# Self-serve add-on prices (AGL-525), minted by tools/scripts/setup-stripe.mjs.
# Per-plan kinds (seat=org-manager, member=host-member); _YEARLY variants
# attach to annual subscriptions (Stripe: one interval per subscription).
STRIPE_PRICE_STARTER_EXTRA_HOST=
STRIPE_PRICE_STARTER_EXTRA_HOST_YEARLY=
STRIPE_PRICE_STARTER_EXTRA_SEAT=
STRIPE_PRICE_STARTER_EXTRA_SEAT_YEARLY=
STRIPE_PRICE_STARTER_EXTRA_MEMBER=
STRIPE_PRICE_STARTER_EXTRA_MEMBER_YEARLY=
STRIPE_PRICE_STARTER_EXTRA_DATASET=
STRIPE_PRICE_STARTER_EXTRA_DATASET_YEARLY=
STRIPE_PRICE_PRO_EXTRA_HOST=
STRIPE_PRICE_PRO_EXTRA_HOST_YEARLY=
STRIPE_PRICE_PRO_EXTRA_SEAT=
STRIPE_PRICE_PRO_EXTRA_SEAT_YEARLY=
STRIPE_PRICE_PRO_EXTRA_MEMBER=
STRIPE_PRICE_PRO_EXTRA_MEMBER_YEARLY=
STRIPE_PRICE_PRO_EXTRA_DATASET=
STRIPE_PRICE_PRO_EXTRA_DATASET_YEARLY=
STRIPE_PRICE_BUSINESS_EXTRA_HOST=
STRIPE_PRICE_BUSINESS_EXTRA_HOST_YEARLY=
STRIPE_PRICE_BUSINESS_EXTRA_SEAT=
STRIPE_PRICE_BUSINESS_EXTRA_SEAT_YEARLY=
STRIPE_PRICE_BUSINESS_EXTRA_MEMBER=
STRIPE_PRICE_BUSINESS_EXTRA_MEMBER_YEARLY=
STRIPE_PRICE_BUSINESS_EXTRA_DATASET=
STRIPE_PRICE_BUSINESS_EXTRA_DATASET_YEARLY=
STRIPE_PRICE_ADVANCED_EXTRA_HOST=
STRIPE_PRICE_ADVANCED_EXTRA_HOST_YEARLY=
STRIPE_PRICE_ADVANCED_EXTRA_SEAT=
STRIPE_PRICE_ADVANCED_EXTRA_SEAT_YEARLY=
STRIPE_PRICE_ADVANCED_EXTRA_MEMBER=
STRIPE_PRICE_ADVANCED_EXTRA_MEMBER_YEARLY=
STRIPE_PRICE_ADVANCED_EXTRA_DATASET=
STRIPE_PRICE_ADVANCED_EXTRA_DATASET_YEARLY=
# Flat add-ons (same price on every plan).
STRIPE_PRICE_POS_REGISTER=
STRIPE_PRICE_POS_REGISTER_YEARLY=
STRIPE_PRICE_EVENT_CALENDAR=
STRIPE_PRICE_EVENT_CALENDAR_YEARLY=

# Signs commerce download + supplier tokens (AGL-509). REQUIRED — the code
# fails closed if unset. `openssl rand -hex 32`. MUST be the SAME value set in
# the tenant app (webhook mints links the tenant verifies).
TOKEN_SIGNING_SECRET=

# ── Scheduled routes (AGL-489/490) ────────────────────────────────────────────
# Shared secret for the cron/scheduled routes (Vercel Cron Authorization header
# or the x-cron-secret header). `openssl rand -hex 32`.
CRON_SECRET=

# ── Plugin platform ───────────────────────────────────────────────────────────
# Ed25519 PRIVATE key that /api/admin/sign-plugin uses to grant realm trust
# (SERVER-ONLY); the public half is NEXT_PUBLIC_PLUGIN_TRUST_PUBLIC_KEY.
PLUGIN_TRUST_PRIVATE_KEY=
NEXT_PUBLIC_PLUGIN_TRUST_PUBLIC_KEY=
NEXT_PUBLIC_PLUGIN_ORIGIN=
PLUGIN_ARTIFACTS_BASE=
PLUGIN_ARTIFACTS_BUCKET=
# Dev-only unverified plugin loop (AGL-516): both must be set to activate.
# NEXT_PUBLIC_PLUGIN_DEV=enabled
# NEXT_PUBLIC_PLUGIN_DEV_BUNDLES=my-plugin=http://localhost:5173/plugin.bundle.mjs

# ── Email (Resend) + staff alerts ─────────────────────────────────────────────
# Setup + DNS runbook: docs/EMAIL_SETUP.md. Key comes from resend.com after the
# aglyn.com domain is verified. USAGE_EMAIL_FROM must be an address on that
# verified domain, e.g. USAGE_EMAIL_FROM="Aglyn <noreply@aglyn.com>".
RESEND_API_KEY=
STAFF_ALERT_EMAIL=
USAGE_EMAIL_FROM=

# ── Custom-domain attach (Vercel API) ─────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_TENANT_PROJECT_ID=
NEXT_PUBLIC_AGLYN_TENANT_HOST_CNAME=
AGLYN_TENANT_HOST_CNAME=
AGLYN_SILOED_HOST=
NEXT_PUBLIC_AGLYN_TENANT_PREVIEW_HOST=

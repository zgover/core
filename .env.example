# Root .env — sourced by the repo tooling in tools/scripts (`set -a && source .env`):
# the manual rules-deploy scripts, set-staff-claim, setup-stripe, seed-e2e, and
# the plugin trust-key tools. ALL SERVER-ONLY SECRETS — never commit a real .env.

# ── Firebase Admin service account ────────────────────────────────────────────
# The service-account JSON fields (from Firebase console → Project settings →
# Service accounts). Used by every Admin-SDK script. FIREBASE_PRIVATE_KEY keeps
# the literal "\n" escapes — the scripts un-escape them.
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=aglyn-main
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n…\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=

# Instance URLs (used by the storage/database rule-deploy scripts).
FIREBASE_DATABASE_URL=https://aglyn-main-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=aglyn-main.appspot.com

# ── Plugin trust chain ────────────────────────────────────────────────────────
# Ed25519 PRIVATE key that signs realm-plugin bundles (generate with
# tools/scripts/generate-plugin-trust-key.mjs). NEVER expose; the matching
# NEXT_PUBLIC_PLUGIN_TRUST_PUBLIC_KEY goes in the apps.
PLUGIN_TRUST_PRIVATE_KEY=

# ── Stripe (setup-stripe.mjs) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_URL=

# ── Vercel (domain/deploy tooling) ────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_CONSOLE_PROJECT_ID=
VERCEL_TENANT_PROJECT_ID=

# ── Local e2e / emulator ──────────────────────────────────────────────────────
E2E_PASSWORD=
# Set these only when pointing scripts at the local emulators:
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8082
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
